      // Backup: Calendar
      var _lvCalYear, _lvCalMonth, _lvCalBackups = [];

      function lvLoadBackupCalendar() {
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'list_backups', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            _lvCalBackups = (data.backups || []);
            var now = new Date();
            _lvCalYear = now.getFullYear();
            _lvCalMonth = now.getMonth();
            lvRenderCalendar();
            if (!_lvCalBackups.length) {
              $('#lvCalEmpty').show();
            } else {
              $('#lvCalEmpty').hide();
            }
          },
          error: function() {
            $('#lvCalEmpty').text('Failed to load backups.').show();
          }
        });
      }

      function lvRenderCalendar() {
        var grid = document.getElementById('lvCalGrid');
        var monthLabel = document.getElementById('lvCalMonth');
        if (!grid || !monthLabel) return;

        var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        monthLabel.textContent = months[_lvCalMonth] + ' ' + _lvCalYear;

        // Remove old day cells (keep 7 header cells)
        while (grid.children.length > 7) grid.removeChild(grid.lastChild);

        var firstDay = new Date(_lvCalYear, _lvCalMonth, 1).getDay();
        var startOffset = (firstDay === 0) ? 6 : firstDay - 1; // Monday-based
        var daysInMonth = new Date(_lvCalYear, _lvCalMonth + 1, 0).getDate();
        var today = new Date();
        var todayStr = today.getFullYear() + '-' + String(today.getMonth()+1).padStart(2,'0') + '-' + String(today.getDate()).padStart(2,'0');

        // Build set of available dates
        var availSet = {};
        _lvCalBackups.forEach(function(b) { availSet[b.date] = b; });

        // Empty cells for offset
        for (var i = 0; i < startOffset; i++) {
          var empty = document.createElement('div');
          empty.className = 'lv-cal-day lv-cal-day--empty';
          grid.appendChild(empty);
        }

        for (var d = 1; d <= daysInMonth; d++) {
          var dateStr = _lvCalYear + '-' + String(_lvCalMonth+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
          var cell = document.createElement('div');
          cell.className = 'lv-cal-day';
          cell.textContent = d;
          cell.setAttribute('data-date', dateStr);

          if (dateStr === todayStr) cell.classList.add('lv-cal-day--today');
          if (dateStr > todayStr) cell.classList.add('lv-cal-day--future');
          if (availSet[dateStr]) {
            cell.classList.add('lv-cal-day--has');
            cell.addEventListener('click', (function(ds) {
              return function() {
                grid.querySelectorAll('.lv-cal-day--sel').forEach(function(el) { el.classList.remove('lv-cal-day--sel'); });
                this.classList.add('lv-cal-day--sel');
                lvShowDownload(ds);
              };
            })(dateStr));
          }
          grid.appendChild(cell);
        }
      }

      function lvShowDownload(dateStr) {
        var dlPanel = document.getElementById('lvCalDownload');
        var dlName = document.getElementById('lvCalDlName');
        var dlMeta = document.getElementById('lvCalDlMeta');
        var dlBtn = document.getElementById('lvCalDlBtn');
        if (!dlPanel) return;

        var backup = null;
        _lvCalBackups.forEach(function(b) { if (b.date === dateStr) backup = b; });
        if (!backup) { dlPanel.style.display = 'none'; return; }

        dlName.textContent = 'logsviewer-' + backup.date + '.zip';
        var parts = [];
        if (backup.contents.system > 0) parts.push('System (' + backup.contents.system + ')');
        if (backup.contents.docker > 0) parts.push('Docker (' + backup.contents.docker + ')');
        if (backup.contents.vms > 0) parts.push('VMs (' + backup.contents.vms + ')');
        dlMeta.textContent = (parts.length ? parts.join(' + ') : 'Empty') + '  ' + lvFormatSize(backup.size);

        dlBtn.href = '/plugins/logsviewer/include/logsviewer_api.php?action=download_backup&date=' + encodeURIComponent(backup.date) + '&_lvt=' + encodeURIComponent(window.lvToken || '');
        dlPanel.style.display = 'flex';
      }

      // Calendar navigation
      $('#lvCalPrev').on('click', function() {
        _lvCalMonth--;
        if (_lvCalMonth < 0) { _lvCalMonth = 11; _lvCalYear--; }
        lvRenderCalendar();
      });
      $('#lvCalNext').on('click', function() {
        var now = new Date();
        if (_lvCalYear > now.getFullYear() || (_lvCalYear === now.getFullYear() && _lvCalMonth >= now.getMonth())) return;
        _lvCalMonth++;
        if (_lvCalMonth > 11) { _lvCalMonth = 0; _lvCalYear++; }
        lvRenderCalendar();
      });

      // ═══════════ CUSTOM LOG PATHS ═══════════

      var _lvCustomPaths = [];
      var _lvCustomPathsLoaded = false;
      var LV_ALLOWED_PREFIXES = ['/var/log/', '/mnt/user/', '/mnt/cache/'];

      function lvValidateCustomPath(path) {
        if (!path || typeof path !== 'string') return false;
        if (path[0] !== '/') return false;
        if (path.indexOf('..') !== -1) return false;
        for (var i = 0; i < LV_ALLOWED_PREFIXES.length; i++) {
          if (path.indexOf(LV_ALLOWED_PREFIXES[i]) === 0) return true;
        }
        return false;
      }

      function lvRenderCustomPathRow(entry, index) {
        var label   = (entry && entry.label) ? entry.label : '';
        var path    = (entry && entry.path)  ? entry.path  : '';
        var invalid = path !== '' && !lvValidateCustomPath(path);
        var rowCls  = 'lv-custom-paths-row' + (invalid ? ' is-invalid' : '');
        return '<div class="' + rowCls + '" data-index="' + index + '">' +
          '<input type="text" class="lv-custom-paths-label" placeholder="Label (e.g. Audit Log)" value="' + lvEscAttr(label) + '">' +
          '<input type="text" class="lv-custom-paths-path"  placeholder="/var/log/your-file.log"  value="' + lvEscAttr(path)  + '">' +
          '<button type="button" class="lv-action-btn lv-custom-paths-remove" title="Remove"><i class="fa fa-trash"></i></button>' +
          (invalid ? '<div class="lv-custom-paths-err">Path must start with /var/log/, /mnt/user/, or /mnt/cache/</div>' : '') +
        '</div>';
      }

      function lvRenderCustomPaths() {
        var html = '';
        if (!_lvCustomPaths.length) {
          html = '<div class="lv-sources-loading">No custom paths defined. Click "Add row" to create one.</div>';
        } else {
          _lvCustomPaths.forEach(function(e, i) { html += lvRenderCustomPathRow(e, i); });
        }
        $('.lv-custom-paths-list').html(html);
        // After a definition change, re-render the per-tab enable lists in Tool/Dash/Backup
        ['Tool','Dash','Backup'].forEach(function(scope) {
          if ($('#lv' + scope + 'CustomLogsList').length) lvRenderCustomLogCheckboxes(scope);
        });
      }

      function lvRenderCustomLogCheckboxes(scope) {
        var $list    = $('#lv' + scope + 'CustomLogsList');
        var $actions = $('#lv' + scope + 'CustomActions');
        var $empty   = $('#lv' + scope + 'CustomEmpty');
        if (!$list.length) return;

        // Read current enabled set from hidden input (preserves user intent
        // across re-renders even if the user hasn't clicked Apply yet).
        var enabledRaw = String($('#lv' + scope + 'EnabledCustomLogs').val() || '');
        var enabledSet = lvCsvToSet(enabledRaw);

        // Build keys from current _lvCustomPaths state (definitions)
        var defs = [];
        _lvCustomPaths.forEach(function(e) {
          if (!e || !e.label || !e.path) return;
          var slug = String(e.label).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
          if (!slug) return;
          defs.push({ key: 'custom:' + slug, name: e.label, path: e.path });
        });

        if (defs.length === 0) {
          $list.empty();
          $actions.hide();
          $empty.show();
          return;
        }
        $empty.hide();

        var html = '';
        defs.forEach(function(d) {
          var checked = !!enabledSet[d.key];
          // Size unknown until next Apply+reload; pass 0 with no disabled state
          html += lvRenderSourceRow(d.key, d.name, d.path, 0, checked, false, '');
        });
        $list.html(html);
        $actions.css('display', 'flex');
      }

      function lvSerializeCustomPaths() {
        // State-driven: _lvCustomPaths is the source of truth, hidden input mirrors it.
        // DOM rows are kept in sync via lvRenderCustomPaths() which renders to ALL .lv-custom-paths-list containers.
        if (_lvCustomPathsLoaded) {
          $('#lvCustomPathsJson').val(JSON.stringify(_lvCustomPaths));
        }
      }

      // Load initial state from hidden input (populated server-side)
      (function() {
        try {
          var raw = $('#lvCustomPathsJson').val() || '[]';
          var arr = JSON.parse(raw);
          if (Array.isArray(arr)) {
            _lvCustomPaths = arr.filter(function(e) { return e && typeof e === 'object'; });
          }
        } catch (e) { _lvCustomPaths = []; }
        _lvCustomPathsLoaded = true;
        lvRenderCustomPaths();
      })();

      $('.lv-custom-paths-add-btn').on('click', function() {
        _lvCustomPaths.push({ label: '', path: '' });
        lvRenderCustomPaths();
        // Focus the newly added label input
        $('.lv-custom-paths-list .lv-custom-paths-row').last().find('.lv-custom-paths-label').focus();
        lvSerializeCustomPaths();
        var f = document.forms['scriptlogs_settings'];
        if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      $(document).on('click', '.lv-custom-paths-remove', function() {
        var idx = parseInt($(this).closest('.lv-custom-paths-row').data('index'), 10);
        if (!isNaN(idx) && idx >= 0 && idx < _lvCustomPaths.length) {
          _lvCustomPaths.splice(idx, 1);
          lvRenderCustomPaths();
          lvSerializeCustomPaths();
          var f = document.forms['scriptlogs_settings'];
          if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
        }
      });

      $(document).on('input change', '.lv-custom-paths-label, .lv-custom-paths-path', function() {
        var $row = $(this).closest('.lv-custom-paths-row');
        var idx  = parseInt($row.data('index'), 10);
        if (!isNaN(idx)) {
          _lvCustomPaths[idx] = {
            label: String($row.find('.lv-custom-paths-label').val() || '').trim(),
            path:  String($row.find('.lv-custom-paths-path').val()  || '').trim()
          };
          // Re-render only this row for validation feedback (defer to avoid input focus loss)
          var pathVal = _lvCustomPaths[idx].path;
          var invalid = pathVal !== '' && !lvValidateCustomPath(pathVal);
          $row.toggleClass('is-invalid', invalid);
          $row.find('.lv-custom-paths-err').remove();
          if (invalid) {
            $row.append('<div class="lv-custom-paths-err">Path must start with /var/log/, /mnt/user/, or /mnt/cache/</div>');
          }
        }
        lvSerializeCustomPaths();
        var f = document.forms['scriptlogs_settings'];
        if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      // ═══════════ NEW BADGE TRACKING (rule editor Tags field) ═══════════
      // Strategy: show the "NEW" badge until the user interacts with any
      // tags input (focus or typing). Persists via localStorage, so once
      // dismissed it stays dismissed across browser sessions.

      var LV_TAGS_BADGE_KEY = 'logsviewer_tags_badge_dismissed';

      function lvIsTagsBadgeDismissed() {
        try {
          return localStorage.getItem(LV_TAGS_BADGE_KEY) === '1';
        } catch (e) { return false; }
      }

      function lvDismissTagsBadge() {
        try { localStorage.setItem(LV_TAGS_BADGE_KEY, '1'); } catch (e) { /* ignore */ }
        // Hide all currently-rendered badges without re-rendering rules
        $('.lv-tags-new-badge').fadeOut(200, function() { $(this).remove(); });
      }

      // Trigger dismissal on first interaction with any tags input
      $(document).on('focus input', '.lv-alert-rule-tags', function() {
        if (!lvIsTagsBadgeDismissed()) lvDismissTagsBadge();
      });

      // ═══════════ ALERTS ═══════════

      var _lvAlertRules = [];
      var _lvAlertRulesLoaded = false;

      var _lvAlertPresets = [
        { name: 'Failed Login', pattern: 'Failed password|authentication failure|Unsuccessful login', is_regex: true, severity: 'warning', sources: ['syslog'], cooldown: '0' },
        { name: 'Disk Error', pattern: 'disk error|I/O error|sector error|SMART error', is_regex: true, severity: 'critical', sources: ['syslog', 'dmesg'], cooldown: '300' },
        { name: 'Out of Memory', pattern: 'Out of memory|oom-killer|OOM', is_regex: true, severity: 'critical', sources: ['syslog', 'dmesg'], cooldown: '900' },
        { name: 'Kernel Panic', pattern: 'kernel panic|BUG:|Oops:', is_regex: true, severity: 'critical', sources: ['syslog', 'dmesg'], cooldown: '0' },
        { name: 'Array Error', pattern: 'md/unraid.*error|array.*error|parity.*error', is_regex: true, severity: 'critical', sources: ['syslog'], cooldown: '300' },
        { name: 'Docker Crash', pattern: 'container died|OOMKilled|exit code', is_regex: true, severity: 'warning', sources: ['docker'], cooldown: '300' }
      ];

      // MITRE ATT&CK techniques relevant to what LogsViewer can actually see
      // in the logs Unraid produces (syslog, dmesg, nginx-error, graphql,
      // phplog, libvirt, docker, custom paths). Curated rather than the full
      // catalogue - only techniques where a sensible regex over these logs
      // can plausibly detect activity. Grouped by ATT&CK tactic so the
      // dropdown renders with <optgroup>s. To extend: add a new item to an
      // existing tactic, or push a new {tactic, items: [...]} object.
      var _lvMitreTechniques = [
        { tactic: 'Initial Access', items: [
          { id: 'T1078',     label: 'Valid Accounts' },
          { id: 'T1133',     label: 'External Remote Services' },
          { id: 'T1190',     label: 'Exploit Public-Facing Application' }
        ]},
        { tactic: 'Execution', items: [
          { id: 'T1059.004', label: 'Command and Scripting Interpreter: Unix Shell' }
        ]},
        { tactic: 'Persistence', items: [
          { id: 'T1053.003', label: 'Scheduled Task/Job: Cron' },
          { id: 'T1505.003', label: 'Server Software Component: Web Shell' },
          { id: 'T1543.002', label: 'Create or Modify System Process: Systemd Service' }
        ]},
        { tactic: 'Privilege Escalation', items: [
          { id: 'T1548.003', label: 'Abuse Elevation Control: Sudo and Sudo Caching' },
          { id: 'T1611',     label: 'Escape to Host' }
        ]},
        { tactic: 'Defense Evasion', items: [
          { id: 'T1070.002', label: 'Indicator Removal: Clear Linux or Mac System Logs' },
          { id: 'T1562.004', label: 'Impair Defenses: Disable or Modify System Firewall' }
        ]},
        { tactic: 'Credential Access', items: [
          { id: 'T1110',     label: 'Brute Force' },
          { id: 'T1110.001', label: 'Brute Force: Password Guessing' },
          { id: 'T1110.003', label: 'Brute Force: Password Spraying' },
          { id: 'T1110.004', label: 'Brute Force: Credential Stuffing' }
        ]},
        { tactic: 'Discovery', items: [
          { id: 'T1018',     label: 'Remote System Discovery' },
          { id: 'T1083',     label: 'File and Directory Discovery' },
          { id: 'T1613',     label: 'Container and Resource Discovery' }
        ]},
        { tactic: 'Lateral Movement', items: [
          { id: 'T1021.004', label: 'Remote Services: SSH' }
        ]},
        { tactic: 'Command and Control', items: [
          { id: 'T1071.001', label: 'Application Layer Protocol: Web Protocols' }
        ]},
        { tactic: 'Reconnaissance', items: [
          { id: 'T1595',     label: 'Active Scanning' }
        ]},
        { tactic: 'Impact', items: [
          { id: 'T1485',     label: 'Data Destruction' },
          { id: 'T1486',     label: 'Data Encrypted for Impact' },
          { id: 'T1490',     label: 'Inhibit System Recovery' }
        ]}
      ];

      // Build the MITRE picker <select> markup once and reuse it across
      // every rule's tags row. The "+ Add MITRE technique..." entry is the
      // placeholder; the change handler resets the picker to it after each
      // selection so the dropdown reads as an additive action rather than
      // a stateful value bound to the rule.
      function lvBuildMitrePickerOptions() {
        var html = '<option value="">+ Add MITRE technique...</option>';
        _lvMitreTechniques.forEach(function(group) {
          html += '<optgroup label="' + lvEscAttr(group.tactic) + '">';
          group.items.forEach(function(t) {
            html += '<option value="' + lvEscAttr(t.id) + '">' +
                    lvEscAttr(t.id) + ' - ' + lvEscAttr(t.label) +
                    '</option>';
          });
          html += '</optgroup>';
        });
        return html;
      }

      var _lvCooldownOptions = [
        { value: '0', label: 'None (every match)' },
        { value: '300', label: '5 minutes' },
        { value: '900', label: '15 minutes' },
        { value: '1800', label: '30 minutes' },
        { value: '3600', label: '1 hour' },
        { value: '21600', label: '6 hours' },
        { value: '86400', label: '24 hours' }
      ];

      function lvGenRuleId() { return 'rule_' + Date.now() + '_' + Math.floor(Math.random() * 1000); }

      function lvEscAttr(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      function lvRenderAlertRule(rule, index) {
        var sevOpts = ['info','warning','critical'].map(function(s) {
          return '<option value="' + s + '"' + (rule.severity === s ? ' selected' : '') + '>' + s.charAt(0).toUpperCase() + s.slice(1) + '</option>';
        }).join('');
        var cdOpts = _lvCooldownOptions.map(function(o) {
          return '<option value="' + o.value + '"' + (String(rule.cooldown) === o.value ? ' selected' : '') + '>' + o.label + '</option>';
        }).join('');
        var checked = (rule.enabled !== false) ? ' checked' : '';
        var regexChecked = rule.is_regex ? ' checked' : '';
        var tagsStr = Array.isArray(rule.tags) ? rule.tags.join(', ') : '';
        var showNew = !lvIsTagsBadgeDismissed();
        var newBadge = showNew ? '<span class="lv-tags-new-badge">NEW</span>' : '';

        return '<div class="lv-alert-rule" data-index="' + index + '">' +
          '<div class="lv-alert-rule-hd">' +
            '<input type="checkbox" class="lv-source-check lv-alert-rule-enabled" title="Enable/Disable"' + checked + '>' +
            '<input type="text" class="lv-alert-rule-name" value="' + lvEscAttr(rule.name) + '" placeholder="Rule name">' +
            '<button type="button" class="lv-action-btn lv-alert-rule-remove" title="Remove rule"><i class="fa fa-trash"></i></button>' +
          '</div>' +
          '<div class="lv-alert-rule-bd">' +
            '<div class="lv-alert-rule-row">' +
              '<span class="lv-alert-rule-lbl">Pattern</span>' +
              '<input type="text" class="lv-alert-rule-pattern" value="' + lvEscAttr(rule.pattern) + '" placeholder="Text or regex pattern">' +
              '<label class="lv-alert-rule-regex" title="Use regex"><input type="checkbox" class="lv-alert-rule-is-regex"' + regexChecked + '> Regex</label>' +
            '</div>' +
            '<div class="lv-alert-rule-row">' +
              '<span class="lv-alert-rule-lbl">Severity</span>' +
              '<select class="lv-alert-rule-severity lv-select">' + sevOpts + '</select>' +
              '<span class="lv-alert-rule-lbl" style="margin-left:12px">Cooldown</span>' +
              '<select class="lv-alert-rule-cooldown lv-select">' + cdOpts + '</select>' +
            '</div>' +
            '<div class="lv-alert-rule-row lv-alert-rule-row--tags">' +
              '<span class="lv-alert-rule-lbl"><i class="fa fa-tags"></i> Tags' + newBadge + '</span>' +
              '<select class="lv-alert-rule-mitre-picker">' + lvBuildMitrePickerOptions() + '</select>' +
              '<input type="text" class="lv-alert-rule-tags" value="' + lvEscAttr(tagsStr) + '" placeholder="e.g. T1110, auth, brute-force">' +
              '<span class="lv-alert-rule-hint">Pick a MITRE technique above or type your own tags below. Comma-separated. Use MITRE technique IDs like T1110 for special highlighting.</span>' +
            '</div>' +
            '<div class="lv-alert-rule-row">' +
              '<span class="lv-alert-rule-lbl">Sources</span>' +
              '<div class="lv-alert-rule-sources">' + lvRenderSourceCheckboxes(rule.sources || []) + '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
      }

      function lvRenderSourceCheckboxes(selected) {
        var sysLogs = ['syslog','dmesg','graphql-api.log','nginx-error','phplog','libvirt'];
        var sysNames = { syslog:'Syslog', dmesg:'Dmesg', 'graphql-api.log':'GraphQL API', 'nginx-error':'Nginx Errors', phplog:'PHP Log', libvirt:'Libvirt' };
        var html = '';
        sysLogs.forEach(function(key) {
          var chk = (selected.indexOf(key) !== -1) ? ' checked' : '';
          html += '<label class="lv-alert-src-chk"><input type="checkbox" value="' + key + '"' + chk + '> ' + (sysNames[key] || key) + '</label>';
        });
        // Custom paths (loaded from hidden CUSTOM_PATHS_JSON, parsed once)
        try {
          var raw = $('#lvCustomPathsJson').val() || '[]';
          var arr = JSON.parse(raw);
          if (Array.isArray(arr)) {
            arr.forEach(function(c) {
              if (!c || !c.label || !c.path) return;
              var slug = String(c.label).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
              if (!slug) return;
              var key = 'custom:' + slug;
              var chk = (selected.indexOf(key) !== -1) ? ' checked' : '';
              html += '<label class="lv-alert-src-chk lv-alert-src-custom"><input type="checkbox" value="' + key + '"' + chk + '> ' + lvEscAttr(c.label) + '</label>';
            });
          }
        } catch (e) { /* ignore parse errors */ }
        var dkChk = (selected.indexOf('docker') !== -1) ? ' checked' : '';
        html += '<label class="lv-alert-src-chk lv-alert-src-sep"><input type="checkbox" value="docker"' + dkChk + '> Docker (all containers)</label>';
        return html;
      }

      function lvSerializeRules() {
        var rules = [];
        $('#lvAlertRulesList .lv-alert-rule').each(function() {
          var $r = $(this);
          var sources = [];
          $r.find('.lv-alert-rule-sources input:checked').each(function() { sources.push($(this).val()); });
          var tagsRaw = String($r.find('.lv-alert-rule-tags').val() || '');
          var tags = tagsRaw.split(',').map(function(t) { return t.trim(); }).filter(function(t) { return t.length > 0 && t.length < 64; });
          rules.push({
            id: $r.data('rule-id') || lvGenRuleId(),
            name: $r.find('.lv-alert-rule-name').val(),
            pattern: $r.find('.lv-alert-rule-pattern').val(),
            is_regex: $r.find('.lv-alert-rule-is-regex').is(':checked'),
            severity: $r.find('.lv-alert-rule-severity').val(),
            sources: sources,
            cooldown: $r.find('.lv-alert-rule-cooldown').val(),
            enabled: $r.find('.lv-alert-rule-enabled').is(':checked'),
            tags: tags
          });
        });
        _lvAlertRules = rules;
        if (_lvAlertRulesLoaded) {
          $('#lvAlertRulesJson').val(JSON.stringify(rules));
        }
      }

      function lvLoadAlertRules() {
        _lvAlertRulesLoaded = false;
        $('#lvAlertAddRule, #lvAlertAddPresets').prop('disabled', true).addClass('disabled');
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'get_alert_rules', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            _lvAlertRules = data.rules || [];
            _lvAlertRulesLoaded = true;
            lvRenderAllRules();
            $('#lvAlertAddRule, #lvAlertAddPresets').prop('disabled', false).removeClass('disabled');
          },
          error: function() {
            _lvAlertRulesLoaded = true;
            _lvAlertRules = [];
            $('#lvAlertRulesList').html('<div class="lv-sources-loading" style="color:#e74c3c;">Failed to load rules. You can still add new rules below.</div>');
            $('#lvAlertAddRule, #lvAlertAddPresets').prop('disabled', false).removeClass('disabled');
          }
        });
      }

      function lvRenderAllRules() {
        var html = '';
        if (_lvAlertRules.length === 0) {
          html = '<div class="lv-sources-loading">No alert rules configured. Click "Add Rule" or "Add Common Rules" to get started.</div>';
        } else {
          _lvAlertRules.forEach(function(rule, i) {
            html += lvRenderAlertRule(rule, i);
          });
        }
        $('#lvAlertRulesList').html(html);
        // Store rule IDs
        $('#lvAlertRulesList .lv-alert-rule').each(function(i) {
          $(this).data('rule-id', _lvAlertRules[i].id || lvGenRuleId());
        });
        lvSerializeRules();
      }

      // Add rule
      $('#lvAlertAddRule').on('click', function() {
        if (!_lvAlertRulesLoaded) return;
        _lvAlertRules.push({ id: lvGenRuleId(), name: '', pattern: '', is_regex: false, severity: 'warning', sources: ['syslog'], cooldown: '3600', enabled: true });
        lvRenderAllRules();
        var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      // Add preset rules
      $('#lvAlertAddPresets').on('click', function() {
        if (!_lvAlertRulesLoaded) return;
        var existingNames = {};
        _lvAlertRules.forEach(function(r) { existingNames[r.name] = true; });
        var added = 0;
        _lvAlertPresets.forEach(function(preset) {
          if (!existingNames[preset.name]) {
            var rule = JSON.parse(JSON.stringify(preset));
            rule.id = lvGenRuleId();
            rule.enabled = true;
            _lvAlertRules.push(rule);
            added++;
          }
        });
        if (added > 0) {
          lvRenderAllRules();
          var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
        }
      });

      // Remove rule
      $(document).on('click', '.lv-alert-rule-remove', function() {
        var idx = $(this).closest('.lv-alert-rule').data('index');
        _lvAlertRules.splice(idx, 1);
        lvRenderAllRules();
        var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      // Rule field changes trigger serialize + dirty
      $(document).on('change input', '.lv-alert-rule input, .lv-alert-rule select', function() {
        lvSerializeRules();
        var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      // MITRE technique picker: when the user selects a technique from the
      // dropdown above the tags input, append the technique ID to the
      // comma-separated tags input below (if not already present), then
      // reset the picker back to its placeholder so it reads as an
      // additive action. Triggers 'input' on the tags input so the
      // existing serialize+dirty handler above re-runs with the new value.
      // Brief visual flash on the tags input confirms the add to the user.
      $(document).on('change', '.lv-alert-rule-mitre-picker', function() {
        var $picker = $(this);
        var techId = String($picker.val() || '').trim();
        if (!techId) return;

        var $tagsInput = $picker.closest('.lv-alert-rule-row--tags').find('.lv-alert-rule-tags');
        var current = String($tagsInput.val() || '')
                        .split(',')
                        .map(function(t) { return t.trim(); })
                        .filter(Boolean);

        // Case-insensitive dedupe so adding "t1110" then T1110 from the
        // picker does not produce a duplicate entry.
        var already = current.some(function(t) { return t.toLowerCase() === techId.toLowerCase(); });
        if (!already) {
          current.push(techId);
          $tagsInput.val(current.join(', ')).trigger('input');

          // Subtle flash on the input border to confirm the technique
          // was added. Inline so the rule does not need its own keyframes.
          var origBorder = $tagsInput[0].style.borderColor;
          $tagsInput.css('border-color', 'var(--lv-accent)');
          setTimeout(function() { $tagsInput.css('border-color', origBorder || ''); }, 350);
        }

        // Always reset the picker back to the placeholder, even on dedupe.
        $picker.val('');
      });

      // Alert History
      var _lvAlertMutes = {};

      function lvIsMitreTag(t) { return /^T\d{4}(\.\d{3})?$/.test(String(t).trim()); }

      // Build the official MITRE ATT&CK URL for a technique ID
      // Main:   T1110     -> https://attack.mitre.org/techniques/T1110/
      // Sub:    T1110.001 -> https://attack.mitre.org/techniques/T1110/001/
      function lvMitreUrl(t) {
        var s = String(t).trim();
        if (!lvIsMitreTag(s)) return null;
        var parts = s.split('.');
        if (parts.length === 2) {
          return 'https://attack.mitre.org/techniques/' + parts[0] + '/' + parts[1] + '/';
        }
        return 'https://attack.mitre.org/techniques/' + parts[0] + '/';
      }

      function lvRenderTagBadges(tags) {
        if (!Array.isArray(tags) || tags.length === 0) return '';
        var html = '<span class="lv-alert-tags">';
        tags.forEach(function(t) {
          var s = String(t).trim();
          if (!s) return;
          if (lvIsMitreTag(s)) {
            var url = lvMitreUrl(s);
            html += '<a href="' + lvEscAttr(url) + '" target="_blank" rel="noopener noreferrer" class="lv-tag lv-tag--mitre" title="View on MITRE ATT&amp;CK (opens in new tab)">' +
                      lvEscAttr(s) +
                      '<i class="fa fa-external-link lv-tag-ext" aria-hidden="true"></i>' +
                    '</a>';
          } else {
            html += '<span class="lv-tag">' + lvEscAttr(s) + '</span>';
          }
        });
        html += '</span>';
        return html;
      }

      function lvRenderSourceLabel(src) {
        if (!src) return '';
        if (src.indexOf('docker:') === 0) return 'docker: ' + src.substring(7);
        if (src.indexOf('custom:') === 0) {
          var slug = src.substring(7);
          return slug.replace(/-/g, ' ');
        }
        return src;
      }

      function lvLoadAlertMutes(cb) {
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'get_alert_mutes', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            _lvAlertMutes = (data && data.mutes && typeof data.mutes === 'object') ? data.mutes : {};
            if (typeof cb === 'function') cb();
          },
          error: function() { _lvAlertMutes = {}; if (typeof cb === 'function') cb(); }
        });
      }

      function lvLoadAlertHistory() {
        // Load mutes first so we can render the muted-state indicator
        lvLoadAlertMutes(function() {
          $.ajax({
            url: '/plugins/logsviewer/include/logsviewer_api.php',
            data: { action: 'get_alert_history', _lvt: window.lvToken || '' },
            dataType: 'json', timeout: 10000,
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            success: function(data) {
              var items = data.history || [];
              if (items.length === 0) {
                $('#lvAlertHistoryList').html('<div class="lv-sources-loading">No alerts triggered yet.</div>');
                return;
              }
              var html = '';
              items.slice(0, 100).forEach(function(a) {
                var sevClass = 'lv-alert-sev--' + (a.severity || 'info');
                var ruleId   = a.rule_id || '';
                var isMuted  = ruleId && _lvAlertMutes[ruleId];
                var menuId   = 'lvAlertMenu_' + Math.random().toString(36).slice(2, 10);
                var mutedHint = isMuted ? '<span class="lv-alert-muted-pill" title="Rule is currently muted"><i class="fa fa-volume-off"></i> muted</span>' : '';
                html += '<div class="lv-alert-history-row' + (isMuted ? ' is-muted' : '') + '" data-rule-id="' + lvEscAttr(ruleId) + '">' +
                  '<span class="lv-alert-history-time">' + lvEscAttr(a.timestamp || '') + '</span>' +
                  '<span class="lv-alert-history-badge ' + sevClass + '">' + lvEscAttr(a.severity || 'info') + '</span>' +
                  '<span class="lv-alert-history-name">' + lvEscAttr(a.rule || '') + lvRenderTagBadges(a.tags || []) + mutedHint + '</span>' +
                  '<span class="lv-alert-history-src">' + lvEscAttr(lvRenderSourceLabel(a.source || '')) + '</span>' +
                  (ruleId ? lvRenderAlertActionMenu(ruleId, !!isMuted, menuId) : '<span class="lv-alert-history-actions-cell"></span>') +
                  '<div class="lv-alert-history-line">' + $('<span>').text(a.matched_line || '').html() + '</div>' +
                '</div>';
              });
              $('#lvAlertHistoryList').html(html);
            },
            error: function() {
              $('#lvAlertHistoryList').html('<div class="lv-sources-loading" style="color:#e74c3c;">Failed to load history.</div>');
            }
          });
        });
      }

      function lvRenderAlertActionMenu(ruleId, isMuted, menuId) {
        var muteSection = isMuted
          ? '<div class="lv-alert-menu-item lv-alert-menu-unmute" data-rule-id="' + lvEscAttr(ruleId) + '"><i class="fa fa-volume-up"></i> Unmute rule</div>'
          : '<div class="lv-alert-menu-header">Mute this rule</div>' +
            '<div class="lv-alert-menu-item" data-action="mute" data-rule-id="' + lvEscAttr(ruleId) + '" data-duration="1h"><i class="fa fa-clock-o"></i> For 1 hour</div>' +
            '<div class="lv-alert-menu-item" data-action="mute" data-rule-id="' + lvEscAttr(ruleId) + '" data-duration="24h"><i class="fa fa-clock-o"></i> For 24 hours</div>' +
            '<div class="lv-alert-menu-item" data-action="mute" data-rule-id="' + lvEscAttr(ruleId) + '" data-duration="7d"><i class="fa fa-calendar"></i> For 7 days</div>' +
            '<div class="lv-alert-menu-sep"></div>' +
            '<div class="lv-alert-menu-item lv-alert-menu-item--danger" data-action="mute" data-rule-id="' + lvEscAttr(ruleId) + '" data-duration="permanent"><i class="fa fa-volume-off"></i> Permanently</div>';

        var btnLabel    = isMuted ? 'Unmute' : 'Mute';
        var btnLeftIcon = isMuted ? 'fa-volume-up' : 'fa-volume-off';
        var btnClass    = 'lv-alert-row-menu-btn' + (isMuted ? ' lv-alert-row-menu-btn--muted' : '');

        return '<div class="lv-alert-history-actions-cell">' +
          '<button type="button" class="' + btnClass + '" data-menu="' + menuId + '" aria-haspopup="true" aria-expanded="false">' +
            '<i class="fa ' + btnLeftIcon + ' lv-amb-icon"></i>' +
            '<span class="lv-amb-label">' + btnLabel + '</span>' +
            '<i class="fa fa-caret-down lv-amb-caret"></i>' +
          '</button>' +
          '<div class="lv-alert-row-menu" id="' + menuId + '" role="menu">' + muteSection + '</div>' +
        '</div>';
      }

      // Open/close 3-dot menu.
      // The menu uses position:fixed and its coordinates are computed from the
      // button's getBoundingClientRect() on open. This way it escapes any
      // ancestor with overflow:hidden / scrollable container, so it can never
      // be clipped at the bottom of the alert-history list.
      function lvCloseAllAlertMenus() {
        $('.lv-alert-row-menu.is-open').each(function() {
          var $m = $(this);
          $m.removeClass('is-open lv-alert-row-menu--up');
          // Clear inline positioning so it doesn't leak between opens
          this.style.top = '';
          this.style.left = '';
          this.style.right = '';
          this.style.bottom = '';
          this.style.maxHeight = '';
        });
        $('.lv-alert-row-menu-btn[aria-expanded="true"]').attr('aria-expanded', 'false');
      }

      function lvPositionAlertMenu(btn, $menu) {
        var menu      = $menu[0];
        // Reset any stale positioning before measuring
        menu.style.top = '';
        menu.style.left = '';
        menu.style.right = '';
        menu.style.bottom = '';
        menu.style.maxHeight = '';

        // Make the menu measurable without flashing on screen
        var prevVis = menu.style.visibility;
        var prevDis = menu.style.display;
        menu.style.visibility = 'hidden';
        menu.style.display = 'block';

        var btnRect    = btn.getBoundingClientRect();
        var menuW      = menu.offsetWidth;
        var menuH      = menu.offsetHeight;
        var vpW        = window.innerWidth || document.documentElement.clientWidth;
        var vpH        = window.innerHeight || document.documentElement.clientHeight;
        var gap        = 4;
        var safePad    = 8; // keep at least this many px from viewport edges

        // Horizontal: align right edge of menu with right edge of button, but
        // never cross the viewport edges.
        var left = btnRect.right - menuW;
        if (left < safePad) left = safePad;
        if (left + menuW > vpW - safePad) left = Math.max(safePad, vpW - safePad - menuW);

        // Vertical: prefer below the button, flip above if not enough room.
        var spaceBelow = vpH - btnRect.bottom - gap - safePad;
        var spaceAbove = btnRect.top - gap - safePad;
        var top;
        var flipUp = false;
        if (menuH <= spaceBelow || spaceBelow >= spaceAbove) {
          top = btnRect.bottom + gap;
          // Cap height if it would overflow the bottom of the viewport
          if (menuH > spaceBelow) menu.style.maxHeight = Math.max(120, spaceBelow) + 'px';
        } else {
          flipUp = true;
          top = btnRect.top - gap - Math.min(menuH, spaceAbove);
          if (menuH > spaceAbove) menu.style.maxHeight = Math.max(120, spaceAbove) + 'px';
        }

        menu.style.left = Math.round(left) + 'px';
        menu.style.top  = Math.round(top)  + 'px';
        if (flipUp) $menu.addClass('lv-alert-row-menu--up'); else $menu.removeClass('lv-alert-row-menu--up');

        // Restore visibility (display will be controlled by .is-open class)
        menu.style.visibility = prevVis;
        menu.style.display = prevDis;
      }

      $(document).on('click', '.lv-alert-row-menu-btn', function(e) {
        e.stopPropagation();
        var btn     = this;
        var $btn    = $(this);
        var menuId  = $btn.data('menu');
        var $menu   = $('#' + menuId);
        if (!$menu.length) return;

        var wasOpen = $menu.hasClass('is-open');
        lvCloseAllAlertMenus();
        if (wasOpen) return; // second click on same button closes it

        lvPositionAlertMenu(btn, $menu);
        $menu.addClass('is-open');
        $btn.attr('aria-expanded', 'true');
      });

      // Close on outside click
      $(document).on('click', function() { lvCloseAllAlertMenus(); });
      // Prevent inner clicks from closing the menu via the outside-click handler
      $(document).on('click', '.lv-alert-row-menu', function(e) { e.stopPropagation(); });
      // Close on scroll/resize so the menu never floats away from its button.
      // Capture phase + passive listener for performance.
      (function() {
        var onScrollOrResize = function() {
          if (document.querySelector('.lv-alert-row-menu.is-open')) lvCloseAllAlertMenus();
        };
        window.addEventListener('scroll', onScrollOrResize, true);
        window.addEventListener('resize', onScrollOrResize);
      })();
      // Close on Escape
      $(document).on('keydown', function(e) {
        if (e.key === 'Escape' || e.keyCode === 27) lvCloseAllAlertMenus();
      });

      // Mute action
      $(document).on('click', '.lv-alert-menu-item[data-action="mute"]', function(e) {
        e.stopPropagation();
        var ruleId   = $(this).data('rule-id');
        var duration = $(this).data('duration');
        if (!ruleId || !duration) return;
        lvCloseAllAlertMenus();
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'set_alert_mute', rule_id: ruleId, duration: duration, _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function() { lvLoadAlertHistory(); },
          error: function() { alert('Failed to mute rule.'); }
        });
      });

      // Unmute action
      $(document).on('click', '.lv-alert-menu-unmute', function(e) {
        e.stopPropagation();
        var ruleId = $(this).data('rule-id');
        if (!ruleId) return;
        lvCloseAllAlertMenus();
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'unset_alert_mute', rule_id: ruleId, _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function() { lvLoadAlertHistory(); },
          error: function() { alert('Failed to unmute rule.'); }
        });
      });

      // Scan Now button
      $('#lvAlertScanNow').on('click', function() {
        var $btn = $(this);
        if ($btn.prop('disabled')) return;
        var origHtml = $btn.html();
        $btn.prop('disabled', true).addClass('disabled').html('<i class="fa fa-spinner fa-spin"></i> Scanning...');
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'run_alerts_scan', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 60000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            var n = (data && typeof data.new_alerts === 'number') ? data.new_alerts : 0;
            var msg = (n === 0) ? 'Scan complete. No new alerts.'
                                : ('Scan complete. ' + n + ' new alert' + (n === 1 ? '' : 's') + ' found.');
            $btn.html('<i class="fa fa-check"></i> ' + (n === 0 ? 'No new alerts' : (n + ' new')));
            setTimeout(function() { $btn.html(origHtml).prop('disabled', false).removeClass('disabled'); }, 2500);
            lvLoadAlertHistory();
            // Lightweight inline toast
            var $toast = $('<div class="lv-toast-inline">' + msg + '</div>');
            $btn.closest('.lv-alert-history-actions').append($toast);
            setTimeout(function() { $toast.fadeOut(400, function() { $toast.remove(); }); }, 2500);
          },
          error: function(xhr) {
            var msg = 'Scan failed.';
            try {
              var resp = xhr.responseJSON || JSON.parse(xhr.responseText || '{}');
              if (resp && resp.message) msg = resp.message;
              else if (resp && resp.busy) msg = 'A scan is already running.';
            } catch (e) {}
            $btn.html('<i class="fa fa-exclamation-triangle"></i> Error');
            setTimeout(function() { $btn.html(origHtml).prop('disabled', false).removeClass('disabled'); }, 2500);
            var $toast = $('<div class="lv-toast-inline lv-toast-inline--error">' + msg + '</div>');
            $btn.closest('.lv-alert-history-actions').append($toast);
            setTimeout(function() { $toast.fadeOut(400, function() { $toast.remove(); }); }, 2500);
          }
        });
      });

      $('#lvAlertClearHistory').on('click', function() {
        var modal = document.getElementById('lvClearHistoryModal');
        if (modal) { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
      });

      // Clear History confirmation modal logic
      (function(){
        var modal = document.getElementById('lvClearHistoryModal');
        if (!modal) return;
        function closeModal() { modal.style.display = 'none'; document.body.style.overflow = ''; }
        document.getElementById('lvClearHistoryCancelBtn').addEventListener('click', closeModal);
        modal.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.style.display === 'flex') closeModal(); });
        document.getElementById('lvClearHistoryConfirmBtn').addEventListener('click', function(){
          closeModal();
          $.ajax({
            url: '/plugins/logsviewer/include/logsviewer_api.php',
            data: { action: 'clear_alert_history', _lvt: window.lvToken || '' },
            dataType: 'json', timeout: 10000,
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            success: function() { lvLoadAlertHistory(); }
          });
        });
      })();

      // Serialize rules on form submit
      var alertForm = document.querySelector('form[name="scriptlogs_settings"]');
      if (alertForm) {
        alertForm.addEventListener('submit', function() { lvSerializeRules(); });
      }

      // Reset confirmation modal
      function lvShowResetModal() {
        var modal = document.getElementById('lvResetModal');
        if (!modal) return;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
      (function(){
        var modal = document.getElementById('lvResetModal');
        var okBtn = document.getElementById('lvResetOkBtn');
        if (!modal) return;
        function close() { modal.style.display = 'none'; document.body.style.overflow = ''; }
        if (okBtn) okBtn.addEventListener('click', close);
        modal.addEventListener('click', function(e){ if (e.target === modal) close(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.style.display === 'flex') close(); });
      })();

      // Credits modal
      (function(){
        var modal = document.getElementById('lvCreditsModal');
        var link  = document.getElementById('lvCreditsLink');
        var okBtn = document.getElementById('lvCreditsOkBtn');
        if (!modal || !link) return;
        function openModal() { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
        function closeModal() { modal.style.display = 'none'; document.body.style.overflow = ''; }
        link.addEventListener('click', function(e){ e.preventDefault(); openModal(); });
        if (okBtn) okBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.style.display === 'flex') closeModal(); });
      })();
    })();
  </script>
</form>

<script>
/*
 * Page width unlocker (same approach as LogsviewerTool.page).
 *
 * The Unraid dynamix template wraps standalone plugin pages in a main
 * content container with a max-width around 1180px. On 2K and 4K monitors
 * this leaves huge gutters. This block walks up from .logsviewer-settings
 * to the document body and removes any max-width constraint on ancestors
 * narrower than the viewport. The wrapper itself uses 80% width with
 * margin auto, so if the script no-ops, layout stays sane and centered.
 */
(function() {
    'use strict';
    function unlockAncestors() {
        var wrap = document.querySelector('.logsviewer-settings');
        if (!wrap) return;
        var vw = window.innerWidth || document.documentElement.clientWidth;
        var el = wrap.parentElement;
        while (el && el !== document.documentElement) {
            var cs = window.getComputedStyle(el);
            var mw = parseFloat(cs.maxWidth);
            if (!isNaN(mw) && mw > 0 && mw < vw) {
                el.style.setProperty('max-width', 'none', 'important');
            }
            el = el.parentElement;
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', unlockAncestors);
    } else {
        unlockAncestors();
    }
    window.addEventListener('resize', unlockAncestors);
})();
</script>
