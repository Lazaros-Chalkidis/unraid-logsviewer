Menu="Utilities"
Icon="img/logsviewermain.png"
Title="Logs Viewer Settings"
---
<?php
require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';
require_once '/usr/local/emhttp/plugins/logsviewer/include/logsviewer_api.php';

$plugin_name = 'logsviewer';
$cfg_file = "/boot/config/plugins/{$plugin_name}/{$plugin_name}.cfg";

// Fixed allowlist (only these logs)
$available_scripts = ['syslog', 'syslog-previous', 'dmesg', 'graphql-api.log', 'nginx-error', 'phplog', 'libvirt'];

// Display name mapping
$script_display_names = [
  'syslog' => 'Syslog',
  'syslog-previous' => 'Syslog Previous',
  'dmesg' => 'Dmesg',
  'graphql-api.log' => 'GraphQL API',
  'nginx-error' => 'Nginx Errors',
  'phplog' => 'PHP Log',
  'libvirt' => 'Libvirt',
];

// Helpers
$yn = static function($v, $default = '0') {
  $v = (string)($v ?? $default);
  return ($v === '1') ? '1' : '0';
};
$clamp_tail = static function($v) {
  $v = (int)$v;
  $allowed = [0, 200, 500, 800, 1500];
  return in_array($v, $allowed, true) ? (string)$v : '0';
};
$sanitize_hex = static function($v, $fallback = '') {
  $v = trim((string)$v);
  if ($v === '') return $fallback;
  if ($v[0] !== '#') $v = '#'.$v;
  if (!preg_match('/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/', $v)) return $fallback;
  if (strlen($v) === 4) {
    $v = '#'.$v[1].$v[1].$v[2].$v[2].$v[3].$v[3];
  }
  return strtolower($v);
};

// Font family allowlist sanitizer (settings UI)
$sanitize_font_family = static function($v, $fallback = 'system') {
  $v = strtolower(trim((string)$v));
  $allowed = ['system','monospace','jetbrains','fira','sourcecodepro','ibmplex'];
  return in_array($v, $allowed, true) ? $v : $fallback;
};

// Whitelist validators for select/enum fields
$sanitize_interval = static function($v) {
  $v = (string)$v;
  $allowed = ['3','5','10','15','30','60'];
  return in_array($v, $allowed, true) ? $v : '10';
};
$sanitize_version = static function($v) {
  $v = strtolower(trim((string)$v));
  $allowed = ['auto','legacy','responsive'];
  return in_array($v, $allowed, true) ? $v : 'auto';
};
$sanitize_theme = static function($v) {
  $v = strtolower(trim((string)$v));
  $allowed = ['default','terminal','dim','contrast','midnight','ocean','monokai'];
  return in_array($v, $allowed, true) ? $v : 'default';
};
$sanitize_highlight_mode = static function($v) {
  $v = strtolower(trim((string)$v));
  $allowed = ['full','keywords'];
  return in_array($v, $allowed, true) ? $v : 'full';
};
$sanitize_syntax_engine = static function($v) {
  $v = strtolower(trim((string)$v));
  $allowed = ['hljs','prism'];
  return in_array($v, $allowed, true) ? $v : 'hljs';
};
$sanitize_export_format = static function($v) {
  $v = strtolower(trim((string)$v));
  $allowed = ['log','txt','json'];
  return in_array($v, $allowed, true) ? $v : 'log';
};
$sanitize_font_size = static function($v) {
  $v = trim((string)$v);
  $allowed = ['0.75rem','0.875rem','1rem','1.125rem','1.25rem'];
  return in_array($v, $allowed, true) ? $v : '1.125rem';
};

// --- Persist new configuration when the form is submitted ---

// NOTE: Reset to defaults is now handled client-side with JavaScript.
// The reset button fills the form fields, then user clicks Apply to save.

if (isset($_POST['#apply'])) {
  // Bootstrap existing cfg for safe defaults (used below)
  $cfg_existing = parse_plugin_cfg($plugin_name, true);

  // ── Resolve ENABLED_SYSTEM_LOGS first (from Sources tab) ──
  // This is the authoritative list; Dashboard/Tool derive from it.
  $enabled_system_logs_raw = $_POST['ENABLED_SYSTEM_LOGS'] ?? ($cfg_existing['ENABLED_SYSTEM_LOGS'] ?? '');

  // ── Dashboard ENABLED_SCRIPTS ──
  // If ENABLED_SCRIPTS[] checkboxes exist in POST, use them (legacy support).
  // Otherwise, derive from the Sources tab's ENABLED_SYSTEM_LOGS.
  if (!empty($_POST['ENABLED_SCRIPTS']) && is_array($_POST['ENABLED_SCRIPTS'])) {
    $selected = array_map('trim', $_POST['ENABLED_SCRIPTS']);
  } else {
    // No script picker in form — sync from ENABLED_SYSTEM_LOGS
    $selected = array_filter(array_map('trim', explode(',', $enabled_system_logs_raw)));
  }

  // Keep only allowed values
  $allow_map = array_flip($available_scripts);
  $selected = array_values(array_filter($selected, function($v) use ($allow_map) {
    return isset($allow_map[$v]);
  }));

  // If nothing selected, default to syslog
  if (empty($selected)) $selected = ['syslog'];

  // ── Tool ENABLED_SCRIPTS ──
  if (!empty($_POST['TOOL_ENABLED_SCRIPTS']) && is_array($_POST['TOOL_ENABLED_SCRIPTS'])) {
    $tool_selected = array_map('trim', $_POST['TOOL_ENABLED_SCRIPTS']);
  } else {
    // No script picker in form — sync from ENABLED_SYSTEM_LOGS
    $tool_selected = array_filter(array_map('trim', explode(',', $enabled_system_logs_raw)));
  }

  $tool_selected = array_values(array_filter($tool_selected, function($v) use ($allow_map) {
    return isset($allow_map[$v]);
  }));

  if (empty($tool_selected)) $tool_selected = ['syslog'];

  // Defaults: keep current behavior; extras OFF until user enables
  $new_cfg = [
    // Dashboard settings
    'REFRESH_ENABLED'   => $yn($_POST['REFRESH_ENABLED'] ?? ($cfg_existing['REFRESH_ENABLED'] ?? '1'), '1'),
    'REFRESH_INTERVAL'  => $sanitize_interval($_POST['REFRESH_INTERVAL'] ?? ($cfg_existing['REFRESH_INTERVAL'] ?? '10')),
    'ENABLED_SCRIPTS'   => implode(',', $selected),
    'SHOW_IDLE_LOGS'    => $yn($_POST['SHOW_IDLE_LOGS'] ?? '0'),
    'LOG_FONT_SIZE'     => $sanitize_font_size($_POST['LOG_FONT_SIZE'] ?? ($cfg_existing['LOG_FONT_SIZE'] ?? '1.125rem')),
    'LOG_BG_COLOR'      => $sanitize_hex($_POST['LOG_BG_COLOR'] ?? ($cfg_existing['LOG_BG_COLOR'] ?? ''), ''),
    'VERSION_OVERRIDE'  => $sanitize_version($_POST['VERSION_OVERRIDE'] ?? ($cfg_existing['VERSION_OVERRIDE'] ?? 'auto')),

    // NEW (extras OFF by default)
    'TAIL_LINES'                 => $clamp_tail($_POST['TAIL_LINES'] ?? ($cfg_existing['TAIL_LINES'] ?? '0')),
    'LOG_FONT_FAMILY'            => $sanitize_font_family($_POST['LOG_FONT_FAMILY'] ?? ($cfg_existing['LOG_FONT_FAMILY'] ?? 'system'), 'system'),
    'THEME_PRESET'               => $sanitize_theme($_POST['THEME_PRESET'] ?? ($cfg_existing['THEME_PRESET'] ?? 'default')),

    'HIGHLIGHT_ENABLED'          => $yn($_POST['HIGHLIGHT_ENABLED'] ?? ($cfg_existing['HIGHLIGHT_ENABLED'] ?? '1'), '1'),
    'HIGHLIGHT_MODE'             => $sanitize_highlight_mode($_POST['HIGHLIGHT_MODE'] ?? ($cfg_existing['HIGHLIGHT_MODE'] ?? 'full')),

    'SYNTAX_HIGHLIGHTING'        => $yn($_POST['SYNTAX_HIGHLIGHTING'] ?? ($cfg_existing['SYNTAX_HIGHLIGHTING'] ?? '0')),
    'SYNTAX_ENGINE'              => $sanitize_syntax_engine($_POST['SYNTAX_ENGINE'] ?? ($cfg_existing['SYNTAX_ENGINE'] ?? 'hljs')),

    'SEARCH_ENABLED'             => $yn($_POST['SEARCH_ENABLED'] ?? '0'),
    'SEARCH_HIGHLIGHT'           => $yn($_POST['SEARCH_HIGHLIGHT'] ?? '0'),

    'AUTO_SCROLL_DEFAULT'         => $yn($_POST['AUTO_SCROLL_DEFAULT'] ?? ($cfg_existing['AUTO_SCROLL_DEFAULT'] ?? '1'), '1'),
    'PAUSE_ON_HOVER'              => $yn($_POST['PAUSE_ON_HOVER'] ?? '0'),

    'SHOW_BADGES'                 => $yn($_POST['SHOW_BADGES'] ?? ($cfg_existing['SHOW_BADGES'] ?? '1'), '1'),
    'SHOW_TOTAL_LINES'            => $yn($_POST['SHOW_TOTAL_LINES'] ?? ($cfg_existing['SHOW_TOTAL_LINES'] ?? '1'), '1'),
    'SHOW_TIMESTAMP'              => $yn($_POST['SHOW_TIMESTAMP'] ?? ($cfg_existing['SHOW_TIMESTAMP'] ?? '1'), '1'),
    'SHOW_FILTER_DROPDOWN'        => $yn($_POST['SHOW_FILTER_DROPDOWN'] ?? ($cfg_existing['SHOW_FILTER_DROPDOWN'] ?? '1'), '1'),
    'SHOW_TOAST'                  => $yn($_POST['SHOW_TOAST'] ?? ($cfg_existing['SHOW_TOAST'] ?? '1'), '1'),

    'EXPORT_FORMAT'               => $sanitize_export_format($_POST['EXPORT_FORMAT'] ?? ($cfg_existing['EXPORT_FORMAT'] ?? 'log')),
    'EXPORT_INCLUDE_TIMESTAMP'    => $yn($_POST['EXPORT_INCLUDE_TIMESTAMP'] ?? ($cfg_existing['EXPORT_INCLUDE_TIMESTAMP'] ?? '1'), '1'),

    // Tool settings (matching ALL Dashboard settings)
    'TOOL_ENABLED_SCRIPTS'           => implode(',', $tool_selected),
    'TOOL_REFRESH_ENABLED'           => $yn($_POST['TOOL_REFRESH_ENABLED'] ?? ($cfg_existing['TOOL_REFRESH_ENABLED'] ?? '1'), '1'),
    'TOOL_REFRESH_INTERVAL'          => $sanitize_interval($_POST['TOOL_REFRESH_INTERVAL'] ?? ($cfg_existing['TOOL_REFRESH_INTERVAL'] ?? '10')),
    'TOOL_SHOW_IDLE_LOGS'            => $yn($_POST['TOOL_SHOW_IDLE_LOGS'] ?? '0'),
    'TOOL_LOG_FONT_SIZE'             => $sanitize_font_size($_POST['TOOL_LOG_FONT_SIZE'] ?? ($cfg_existing['TOOL_LOG_FONT_SIZE'] ?? '1.125rem')),
    'TOOL_LOG_FONT_FAMILY'           => $sanitize_font_family($_POST['TOOL_LOG_FONT_FAMILY'] ?? ($cfg_existing['TOOL_LOG_FONT_FAMILY'] ?? 'system'), 'system'),
    'TOOL_LOG_BG_COLOR'              => $sanitize_hex($_POST['TOOL_LOG_BG_COLOR'] ?? ($cfg_existing['TOOL_LOG_BG_COLOR'] ?? ''), ''),
    'TOOL_THEME_PRESET'              => $sanitize_theme($_POST['TOOL_THEME_PRESET'] ?? ($cfg_existing['TOOL_THEME_PRESET'] ?? 'default')),
    'TOOL_HIGHLIGHT_ENABLED'         => $yn($_POST['TOOL_HIGHLIGHT_ENABLED'] ?? ($cfg_existing['TOOL_HIGHLIGHT_ENABLED'] ?? '1'), '1'),
    'TOOL_HIGHLIGHT_MODE'            => $sanitize_highlight_mode($_POST['TOOL_HIGHLIGHT_MODE'] ?? ($cfg_existing['TOOL_HIGHLIGHT_MODE'] ?? 'full')),
    'TOOL_TAIL_LINES'                => $clamp_tail($_POST['TOOL_TAIL_LINES'] ?? ($cfg_existing['TOOL_TAIL_LINES'] ?? '0')),
    'TOOL_SEARCH_ENABLED'            => $yn($_POST['TOOL_SEARCH_ENABLED'] ?? '0'),
    'TOOL_SEARCH_HIGHLIGHT'          => $yn($_POST['TOOL_SEARCH_HIGHLIGHT'] ?? '0'),
    'TOOL_SYNTAX_HIGHLIGHTING'       => $yn($_POST['TOOL_SYNTAX_HIGHLIGHTING'] ?? ($cfg_existing['TOOL_SYNTAX_HIGHLIGHTING'] ?? '0')),
    'TOOL_SYNTAX_ENGINE'          => $sanitize_syntax_engine($_POST['TOOL_SYNTAX_ENGINE'] ?? ($cfg_existing['TOOL_SYNTAX_ENGINE'] ?? 'hljs')),
    'TOOL_AUTO_SCROLL_DEFAULT'       => $yn($_POST['TOOL_AUTO_SCROLL_DEFAULT'] ?? ($cfg_existing['TOOL_AUTO_SCROLL_DEFAULT'] ?? '1'), '1'),
    'TOOL_PAUSE_ON_HOVER'            => $yn($_POST['TOOL_PAUSE_ON_HOVER'] ?? '0'),
    'TOOL_SHOW_BADGES'               => $yn($_POST['TOOL_SHOW_BADGES'] ?? ($cfg_existing['TOOL_SHOW_BADGES'] ?? '1'), '1'),
    'TOOL_SHOW_TOTAL_LINES'          => $yn($_POST['TOOL_SHOW_TOTAL_LINES'] ?? ($cfg_existing['TOOL_SHOW_TOTAL_LINES'] ?? '1'), '1'),
    'TOOL_SHOW_TIMESTAMP'            => $yn($_POST['TOOL_SHOW_TIMESTAMP'] ?? ($cfg_existing['TOOL_SHOW_TIMESTAMP'] ?? '1'), '1'),
    'TOOL_SHOW_FILTER_DROPDOWN'      => $yn($_POST['TOOL_SHOW_FILTER_DROPDOWN'] ?? ($cfg_existing['TOOL_SHOW_FILTER_DROPDOWN'] ?? '1'), '1'),
    'TOOL_SHOW_TOAST'                => $yn($_POST['TOOL_SHOW_TOAST'] ?? ($cfg_existing['TOOL_SHOW_TOAST'] ?? '1'), '1'),
    'TOOL_EXPORT_FORMAT'             => $sanitize_export_format($_POST['TOOL_EXPORT_FORMAT'] ?? ($cfg_existing['TOOL_EXPORT_FORMAT'] ?? 'log')),
    'TOOL_EXPORT_INCLUDE_TIMESTAMP'  => $yn($_POST['TOOL_EXPORT_INCLUDE_TIMESTAMP'] ?? ($cfg_existing['TOOL_EXPORT_INCLUDE_TIMESTAMP'] ?? '1'), '1'),

    // Log Sources (independent per Dashboard/Tool)
    // Dashboard sources are independent: do NOT fall back to shared/global keys.
    'DASH_ENABLED_SYSTEM_LOGS'       => $_POST['DASH_ENABLED_SYSTEM_LOGS'] ?? ($cfg_existing['DASH_ENABLED_SYSTEM_LOGS'] ?? 'syslog,dmesg,graphql-api.log,nginx-error'),
    'DASH_ENABLED_DOCKER_CONTAINERS' => $_POST['DASH_ENABLED_DOCKER_CONTAINERS'] ?? ($cfg_existing['DASH_ENABLED_DOCKER_CONTAINERS'] ?? ''),
    'DASH_ENABLED_VMS'               => $_POST['DASH_ENABLED_VMS'] ?? ($cfg_existing['DASH_ENABLED_VMS'] ?? ''),

    // Tool defaults: system logs only; docker/vm empty until user enables
    'TOOL_ENABLED_SYSTEM_LOGS'       => $_POST['TOOL_ENABLED_SYSTEM_LOGS'] ?? ($cfg_existing['TOOL_ENABLED_SYSTEM_LOGS'] ?? 'syslog,dmesg,graphql-api.log,nginx-error'),
    'TOOL_ENABLED_DOCKER_CONTAINERS' => $_POST['TOOL_ENABLED_DOCKER_CONTAINERS'] ?? ($cfg_existing['TOOL_ENABLED_DOCKER_CONTAINERS'] ?? ''),
    'TOOL_ENABLED_VMS'               => $_POST['TOOL_ENABLED_VMS'] ?? ($cfg_existing['TOOL_ENABLED_VMS'] ?? ''),

    // Log Sources (shared between Dashboard and Tool)
    'ENABLED_SYSTEM_LOGS'        => $_POST['ENABLED_SYSTEM_LOGS'] ?? ($cfg_existing['ENABLED_SYSTEM_LOGS'] ?? ''),
    'ENABLED_DOCKER_CONTAINERS'  => $_POST['ENABLED_DOCKER_CONTAINERS'] ?? ($cfg_existing['ENABLED_DOCKER_CONTAINERS'] ?? ''),
    'ENABLED_VMS'                => $_POST['ENABLED_VMS'] ?? ($cfg_existing['ENABLED_VMS'] ?? ''),

    // Backup settings
    'BACKUP_ENABLED'                  => $yn($_POST['BACKUP_ENABLED'] ?? ($cfg_existing['BACKUP_ENABLED'] ?? '0')),
    'BACKUP_RETENTION'                => in_array($_POST['BACKUP_RETENTION'] ?? '', ['1','2','3','4','5','6'], true) ? $_POST['BACKUP_RETENTION'] : ($cfg_existing['BACKUP_RETENTION'] ?? '3'),
    'BACKUP_STORAGE'                  => (strncmp($_POST['BACKUP_STORAGE'] ?? '', '/mnt/user/', 10) === 0 && !preg_match('/\.\./', $_POST['BACKUP_STORAGE'])) ? rtrim($_POST['BACKUP_STORAGE'], '/') : ($cfg_existing['BACKUP_STORAGE'] ?? '/mnt/user/appdata/Logs-Viewer-Backup'),
    'BACKUP_SCHEDULE'                 => in_array($_POST['BACKUP_SCHEDULE'] ?? '', ['0','2','4','6','23'], true) ? $_POST['BACKUP_SCHEDULE'] : ($cfg_existing['BACKUP_SCHEDULE'] ?? '23'),
    'BACKUP_ENABLED_SYSTEM_LOGS'      => $_POST['BACKUP_ENABLED_SYSTEM_LOGS'] ?? ($cfg_existing['BACKUP_ENABLED_SYSTEM_LOGS'] ?? ''),
    'BACKUP_ENABLED_DOCKER_CONTAINERS'=> $_POST['BACKUP_ENABLED_DOCKER_CONTAINERS'] ?? ($cfg_existing['BACKUP_ENABLED_DOCKER_CONTAINERS'] ?? ''),
    'BACKUP_ENABLED_VMS'              => $_POST['BACKUP_ENABLED_VMS'] ?? ($cfg_existing['BACKUP_ENABLED_VMS'] ?? ''),

    // Alerts settings
    'ALERTS_ENABLED'                  => $yn($_POST['ALERTS_ENABLED'] ?? ($cfg_existing['ALERTS_ENABLED'] ?? '0')),
    'ALERTS_INTERVAL'                 => in_array($_POST['ALERTS_INTERVAL'] ?? '', ['1','2','5'], true) ? $_POST['ALERTS_INTERVAL'] : ($cfg_existing['ALERTS_INTERVAL'] ?? '2'),

    // UI state (survives AJAX POST + GET reload cycle)
    'LV_ACTIVE_TAB'              => in_array($_POST['lv_active_tab'] ?? '', ['dash','tool','backup','alerts'], true) ? $_POST['lv_active_tab'] : ($cfg_existing['LV_ACTIVE_TAB'] ?? 'dash'),
  ];

  // Normalize a few options safely
  $allowed_fonts = ['system','monospace','jetbrains','fira','sourcecodepro','ibmplex'];
  if (!in_array($new_cfg['LOG_FONT_FAMILY'], $allowed_fonts, true)) $new_cfg['LOG_FONT_FAMILY'] = 'system';

  $allowed_presets = ['default','terminal','dim','contrast','midnight','ocean','monokai'];
  if (!in_array($new_cfg['THEME_PRESET'], $allowed_presets, true)) $new_cfg['THEME_PRESET'] = 'default';

  $allowed_hm = ['full','keywords'];
  if (!in_array($new_cfg['HIGHLIGHT_MODE'], $allowed_hm, true)) $new_cfg['HIGHLIGHT_MODE'] = 'full';

  $allowed_export = ['log','txt','json'];
  if (!in_array($new_cfg['EXPORT_FORMAT'], $allowed_export, true)) $new_cfg['EXPORT_FORMAT'] = 'log';

  // Normalize Tool options
  if (!in_array($new_cfg['TOOL_LOG_FONT_FAMILY'], $allowed_fonts, true)) $new_cfg['TOOL_LOG_FONT_FAMILY'] = 'system';
  if (!in_array($new_cfg['TOOL_THEME_PRESET'], $allowed_presets, true)) $new_cfg['TOOL_THEME_PRESET'] = 'default';
  if (!in_array($new_cfg['TOOL_HIGHLIGHT_MODE'], $allowed_hm, true)) $new_cfg['TOOL_HIGHLIGHT_MODE'] = 'full';
  if (!in_array($new_cfg['TOOL_EXPORT_FORMAT'], $allowed_export, true)) $new_cfg['TOOL_EXPORT_FORMAT'] = 'log';

  // Whitelist remaining free-text fields
  $allowed_version = ['auto','legacy','responsive'];
  if (!in_array($new_cfg['VERSION_OVERRIDE'], $allowed_version, true)) $new_cfg['VERSION_OVERRIDE'] = 'auto';

  $allowed_engine = ['hljs','prism'];
  if (!in_array($new_cfg['SYNTAX_ENGINE'] ?? 'hljs', $allowed_engine, true)) $new_cfg['SYNTAX_ENGINE'] = 'hljs';
  if (!in_array($new_cfg['TOOL_SYNTAX_ENGINE'] ?? 'hljs', $allowed_engine, true)) $new_cfg['TOOL_SYNTAX_ENGINE'] = 'hljs';

  // Clamp numeric fields
  $new_cfg['REFRESH_INTERVAL']      = max(1, min(3600, (int)$new_cfg['REFRESH_INTERVAL']));
  $new_cfg['TOOL_REFRESH_INTERVAL'] = max(1, min(3600, (int)$new_cfg['TOOL_REFRESH_INTERVAL']));

  // Binary fields: force '0' or '1'
  foreach (['REFRESH_ENABLED','TOOL_REFRESH_ENABLED','SYNTAX_HIGHLIGHTING','TOOL_SYNTAX_HIGHLIGHTING'] as $_bf) {
    $new_cfg[$_bf] = ($new_cfg[$_bf] === '1') ? '1' : '0';
  }

  // Serialize cfg (strip control characters to prevent INI injection)
  $ini = '';
  foreach ($new_cfg as $key => $value) {
    $value = preg_replace('/[\x00-\x1f\x7f]/', '', (string)$value);
    $value = str_replace('"', '\"', $value);
    $ini .= "{$key}=\"{$value}\"\n";
  }
  file_put_contents($cfg_file, $ini);

  // Cron management - Unraid uses /etc/cron.d/root for all entries
  $cronRoot = '/etc/cron.d/root';
  $cronFlash = '/boot/config/plugins/logsviewer/logsviewer-cron.conf';
  $cronContent = is_file($cronRoot) ? (string)@file_get_contents($cronRoot) : '';

  // Remove existing logsviewer lines
  $cronContent = preg_replace('/# LogsViewer backup schedule:\n.*logsviewer-backup\.sh.*\n?/', '', $cronContent);
  $cronContent = preg_replace('/# LogsViewer alerts schedule:\n.*logsviewer-alerts\.sh.*\n?/', '', $cronContent);
  $cronContent = rtrim($cronContent) . "\n";

  $flashLines = '';

  // Backup cron
  if (($new_cfg['BACKUP_ENABLED'] ?? '0') === '1') {
    $schedHour = (int)($new_cfg['BACKUP_SCHEDULE'] ?? 23);
    $schedMin  = ($schedHour === 23) ? 59 : 0;
    $backupLine = "# LogsViewer backup schedule:\n{$schedMin} {$schedHour} * * * /usr/local/emhttp/plugins/logsviewer/logsviewer-backup.sh >/dev/null 2>&1\n";
    $cronContent .= $backupLine;
    $flashLines .= $backupLine;
    // Create backup dir + block Samba access via permissions
    $backupPath = (string)($new_cfg['BACKUP_STORAGE'] ?? '');
    if ($backupPath !== '' && strncmp($backupPath, '/mnt/user/', 10) === 0) {
      @mkdir($backupPath, 0700, true);
      if (is_dir($backupPath)) @chmod($backupPath, 0700);
    }
  }

  // Alerts cron
  if (($new_cfg['ALERTS_ENABLED'] ?? '0') === '1') {
    $alertInterval = (int)($new_cfg['ALERTS_INTERVAL'] ?? 5);
    if ($alertInterval < 1) $alertInterval = 5;
    $alertLine = "# LogsViewer alerts schedule:\n*/{$alertInterval} * * * * /usr/local/emhttp/plugins/logsviewer/logsviewer-alerts.sh >/dev/null 2>&1\n";
    $cronContent .= $alertLine;
    $flashLines .= $alertLine;
  }

  @file_put_contents($cronRoot, $cronContent);
  @exec('crontab /etc/cron.d/root 2>/dev/null');
  // Persist to flash for boot restore
  if ($flashLines !== '') {
    @file_put_contents($cronFlash, $flashLines);
  } else {
    if (is_file($cronFlash)) @unlink($cronFlash);
  }
  // Cleanup old separate cron files
  foreach (['/etc/cron.d/logsviewer-backup','/etc/cron.d/logsviewer-alerts','/boot/config/plugins/logsviewer/logsviewer-backup.cron','/boot/config/plugins/logsviewer/logsviewer-alerts.cron'] as $_old) {
    if (is_file($_old)) @unlink($_old);
  }

  // Save alert rules JSON (only when alerts tab is active to prevent stale data overwrite)
  $activeTab = $_POST['lv_active_tab'] ?? 'dash';
  $alertRulesRaw = (string)($_POST['ALERT_RULES_JSON'] ?? '');
  if ($activeTab === 'alerts' && $alertRulesRaw !== '') {
    $alertRules = @json_decode($alertRulesRaw, true);
    if (is_array($alertRules)) {
      @file_put_contents('/boot/config/plugins/logsviewer/alerts-rules.json', json_encode($alertRules, JSON_PRETTY_PRINT));
    }
  }

  $cfg = $new_cfg;
} else {
  $cfg = parse_plugin_cfg($plugin_name, true);
}

// ---------------------------------------------------------------------------
// Migration (B): One-time legacy/global -> DASH_* only (Tool stays clean).
// Runs only if DASH_* missing and MIGRATED_DASH_SOURCES not set.
// ---------------------------------------------------------------------------
if (($cfg['MIGRATED_DASH_SOURCES'] ?? '0') !== '1' && !array_key_exists('DASH_ENABLED_SYSTEM_LOGS', $cfg)) {
  $legacy_sys    = (string)($cfg['ENABLED_SYSTEM_LOGS'] ?? ($cfg['ENABLED_SCRIPTS'] ?? ''));
  $legacy_docker = (string)($cfg['ENABLED_DOCKER_CONTAINERS'] ?? '');
  $legacy_vms    = (string)($cfg['ENABLED_VMS'] ?? '');

  if ($legacy_sys !== '' || $legacy_docker !== '' || $legacy_vms !== '') {
    $cfg['DASH_ENABLED_SYSTEM_LOGS']       = $legacy_sys;
    $cfg['DASH_ENABLED_DOCKER_CONTAINERS'] = $legacy_docker;
    $cfg['DASH_ENABLED_VMS']               = $legacy_vms;
    $cfg['MIGRATED_DASH_SOURCES']          = '1';

    // Persist migration to cfg file
    $ini = '';
    foreach ($cfg as $key => $value) {
      $value = preg_replace('/[\x00-\x1f\x7f]/', '', (string)$value);
      $value = str_replace('"', '\"', $value);
      $ini .= "{$key}=\"{$value}\"\n";
    }
    file_put_contents($cfg_file, $ini);
  }
}

// Hide developer-only controls in main release builds
$branch_meta_file = '/usr/local/emhttp/plugins/logsviewer/branch.meta';
$is_main_branch = true;
if (file_exists($branch_meta_file)) {
    $branch_meta = parse_ini_file($branch_meta_file);
    $is_main_branch = ($branch_meta['IS_MAIN_BRANCH'] ?? '1') === '1';
}

$enabled_scripts_array = isset($cfg['ENABLED_SCRIPTS']) ? array_filter(array_map('trim', explode(',', $cfg['ENABLED_SCRIPTS']))) : ['syslog'];
