      <div class="lv-sec-hd" onclick="this.parentElement.classList.toggle('closed')">
        <span>Log display</span>
        <span class="lv-pill">Appearance</span>
        <span class="lv-sec-arrow">&#9650;</span>
      </div>
      <div class="lv-sec-bd">
        <div class="lv-r">
          <div class="lv-r-label">Log font size</div>
          <div class="lv-r-field">
            <select name="TOOL_LOG_FONT_SIZE" class="lv-select">
              <?php $fs = $cfg['TOOL_LOG_FONT_SIZE'] ?? '1.125rem';
                foreach(['0.75rem'=>'Extra Small','0.875rem'=>'Small','1rem'=>'Medium','1.125rem'=>'Large - Default','1.25rem'=>'Extra Large'] as $v=>$l) echo '<option value="'.$v.'"'.($fs===$v?' selected':'').'>'.$l.'</option>'; ?>
