      <?php 
        $plugin_version = '';

        // Method 1: PLG file <version> tag
        $plugin_info_file = '/boot/config/plugins/logsviewer/logsviewer.plg';
        if (file_exists($plugin_info_file)) {
          $plg_content = @file_get_contents($plugin_info_file);
          if ($plg_content && preg_match('/<ENTITY\s+version\s+"([^"]+)"/i', $plg_content, $matches)) {
            $plugin_version = $matches[1];
          }
          if (!$plugin_version && $plg_content && preg_match('/<version>(.*?)<\/version>/i', $plg_content, $matches)) {
            $plugin_version = $matches[1];
          }
        }

        // Method 2: TXZ filename in packages directory
        if (!$plugin_version) {
          $txz_pattern = '/boot/config/plugins/logsviewer/logsviewer-*.txz';
          $txz_files = glob($txz_pattern);
          if ($txz_files) {
            $txz_name = basename(end($txz_files));
            if (preg_match('/logsviewer-(\d{4}\.\d{2}\.\d{2}[a-z]?)/', $txz_name, $matches)) {
              $plugin_version = $matches[1];
            }
          }
        }

        // Method 3: Installed package version
        if (!$plugin_version) {
          $pkg_pattern = '/var/log/packages/logsviewer-*';
          $pkg_files = glob($pkg_pattern);
          if ($pkg_files) {
            $pkg_name = basename(end($pkg_files));
            if (preg_match('/logsviewer-(\d{4}\.\d{2}\.\d{2}[a-z]?)/', $pkg_name, $matches)) {
              $plugin_version = $matches[1];
            }
          }
        }

        if (!$plugin_version) $plugin_version = 'dev';
        echo _('Version: ') . htmlspecialchars($plugin_version);
      ?>
    </div>
