    'SEARCH_ENABLED'             => isset($_POST['SEARCH_ENABLED']) ? '1' : '0',
    'SEARCH_HIGHLIGHT'           => isset($_POST['SEARCH_HIGHLIGHT']) ? '1' : '0',

    'AUTO_SCROLL_DEFAULT'         => $yn($_POST['AUTO_SCROLL_DEFAULT'] ?? ($cfg_existing['AUTO_SCROLL_DEFAULT'] ?? '1'), '1'),
    'PAUSE_ON_HOVER'              => isset($_POST['PAUSE_ON_HOVER']) ? '1' : '0',

    'REFRESH_ONLY_WHEN_RUNNING'   => isset($_POST['REFRESH_ONLY_WHEN_RUNNING']) ? '1' : '0',

    'SHOW_BADGES'                 => $yn($_POST['SHOW_BADGES'] ?? ($cfg_existing['SHOW_BADGES'] ?? '1'), '1'),
    'SHOW_TOTAL_LINES'            => $yn($_POST['SHOW_TOTAL_LINES'] ?? ($cfg_existing['SHOW_TOTAL_LINES'] ?? '1'), '1'),
    'SHOW_TIMESTAMP'              => $yn($_POST['SHOW_TIMESTAMP'] ?? ($cfg_existing['SHOW_TIMESTAMP'] ?? '1'), '1'),
    'SHOW_FILTER_DROPDOWN'        => $yn($_POST['SHOW_FILTER_DROPDOWN'] ?? ($cfg_existing['SHOW_FILTER_DROPDOWN'] ?? '1'), '1'),
    'SHOW_TOAST'                  => $yn($_POST['SHOW_TOAST'] ?? ($cfg_existing['SHOW_TOAST'] ?? '1'), '1'),

    'EXPORT_FORMAT'               => $_POST['EXPORT_FORMAT'] ?? ($cfg_existing['EXPORT_FORMAT'] ?? 'log'),
    'EXPORT_INCLUDE_TIMESTAMP'    => $yn($_POST['EXPORT_INCLUDE_TIMESTAMP'] ?? ($cfg_existing['EXPORT_INCLUDE_TIMESTAMP'] ?? '1'), '1'),

    // Tool settings (matching ALL Dashboard settings)
    'TOOL_ENABLED_SCRIPTS'           => implode(',', $tool_selected),
    'TOOL_REFRESH_ENABLED'           => $_POST['TOOL_REFRESH_ENABLED'] ?? ($cfg_existing['TOOL_REFRESH_ENABLED'] ?? '1'),
    'TOOL_REFRESH_INTERVAL'          => $_POST['TOOL_REFRESH_INTERVAL'] ?? ($cfg_existing['TOOL_REFRESH_INTERVAL'] ?? '10'),
    'TOOL_SHOW_IDLE_LOGS'            => isset($_POST['TOOL_SHOW_IDLE_LOGS']) ? '1' : '0',
    'TOOL_REFRESH_ONLY_WHEN_RUNNING' => isset($_POST['TOOL_REFRESH_ONLY_WHEN_RUNNING']) ? '1' : '0',
    'TOOL_LOG_FONT_SIZE'             => $_POST['TOOL_LOG_FONT_SIZE'] ?? ($cfg_existing['TOOL_LOG_FONT_SIZE'] ?? '1rem'),
    'TOOL_LOG_FONT_FAMILY'           => $sanitize_font_family($_POST['TOOL_LOG_FONT_FAMILY'] ?? ($cfg_existing['TOOL_LOG_FONT_FAMILY'] ?? 'system'), 'system'),
    'TOOL_LOG_BG_COLOR'              => $sanitize_hex($_POST['TOOL_LOG_BG_COLOR'] ?? ($cfg_existing['TOOL_LOG_BG_COLOR'] ?? ''), ''),
    'TOOL_THEME_PRESET'              => $_POST['TOOL_THEME_PRESET'] ?? ($cfg_existing['TOOL_THEME_PRESET'] ?? 'default'),
    'TOOL_HIGHLIGHT_ENABLED'         => $yn($_POST['TOOL_HIGHLIGHT_ENABLED'] ?? ($cfg_existing['TOOL_HIGHLIGHT_ENABLED'] ?? '1'), '1'),
    'TOOL_HIGHLIGHT_MODE'            => $_POST['TOOL_HIGHLIGHT_MODE'] ?? ($cfg_existing['TOOL_HIGHLIGHT_MODE'] ?? 'full'),
    'TOOL_TAIL_LINES'                => $clamp_tail($_POST['TOOL_TAIL_LINES'] ?? ($cfg_existing['TOOL_TAIL_LINES'] ?? '0')),
    'TOOL_SEARCH_ENABLED'            => isset($_POST['TOOL_SEARCH_ENABLED']) ? '1' : '0',
    'TOOL_SEARCH_HIGHLIGHT'          => isset($_POST['TOOL_SEARCH_HIGHLIGHT']) ? '1' : '0',
    'TOOL_SYNTAX_HIGHLIGHTING'       => $_POST['TOOL_SYNTAX_HIGHLIGHTING'] ?? ($cfg_existing['TOOL_SYNTAX_HIGHLIGHTING'] ?? '0'),
    'TOOL_SYNTAX_ENGINE'          => $_POST['TOOL_SYNTAX_ENGINE'] ?? ($cfg_existing['TOOL_SYNTAX_ENGINE'] ?? 'hljs'),
    'TOOL_AUTO_SCROLL_DEFAULT'       => $yn($_POST['TOOL_AUTO_SCROLL_DEFAULT'] ?? ($cfg_existing['TOOL_AUTO_SCROLL_DEFAULT'] ?? '1'), '1'),
    'TOOL_PAUSE_ON_HOVER'            => isset($_POST['TOOL_PAUSE_ON_HOVER']) ? '1' : '0',
