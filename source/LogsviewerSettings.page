  </div>

  <script>
    window.lvToken = <?php echo json_encode(LogsViewerEndpoint::generateNonce()); ?>;
  </script>
  <script>
    function _lv_isLight() {
      var el = document.querySelector('.logsviewer-settings');
      return el && el.classList.contains('lv-light');
    }
    (function () {

      // Toggle switch: update text label on change
      document.addEventListener('change', function(e) {
        var cb = e.target;
        if (cb.type !== 'checkbox') return;
        var tog = cb.closest('.lv-toggle');
        if (!tog) return;
        var txt = tog.parentElement.querySelector('.lv-toggle-txt');
        if (!txt) return;
        var on = cb.checked;
        var onLabel = txt.getAttribute('data-on') || (txt.textContent.match(/show|hide/i) ? 'Show' : 'Enabled');
        var offLabel = txt.getAttribute('data-off') || (onLabel === 'Show' ? 'Hide' : 'Disabled');
        txt.textContent = on ? onLabel : offLabel;
        txt.className = 'lv-toggle-txt ' + (on ? 'on' : 'off');
      });

      // Store on/off labels from initial state
      document.querySelectorAll('.lv-toggle-txt').forEach(function(txt) {
        var isOn = txt.classList.contains('on');
        var text = txt.textContent.trim();
        if (isOn) {
          txt.setAttribute('data-on', text);
          txt.setAttribute('data-off', text === 'Show' ? 'Hide' : text === 'Enabled' ? 'Disabled' : 'Off');
        } else {
          txt.setAttribute('data-off', text);
          txt.setAttribute('data-on', text === 'Hide' ? 'Show' : text === 'Disabled' ? 'Enabled' : 'On');
        }
      });

      // Color picker sync
      function normalizeHex(v){
        v = (v || '').trim();
        if (!v) return '';
        if (v[0] !== '#') v = '#' + v;
        if (!/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(v)) return '';
        if (v.length === 4) v = '#' + v[1]+v[1] + v[2]+v[2] + v[3]+v[3];
        return v.toLowerCase();
      }

      // Dashboard color picker
      const picker = document.getElementById('lvBgColorPicker');
      const hex = document.getElementById('lvBgColorHex');
      const hidden = document.getElementById('lvBgColorHidden');
      const preview = document.getElementById('lvBgPreview');

      if (picker && hex && hidden && preview){
        const form = picker.closest('form') || document.forms['scriptlogs_settings'];

        function forceEnableApply(){
          const applyBtn = document.querySelector('[name="#apply"]');
          if (applyBtn) { applyBtn.disabled = false; applyBtn.removeAttribute('disabled'); applyBtn.classList.remove('disabled'); }
          if (form) try { form.dispatchEvent(new Event('change', { bubbles: true })); } catch (_) {}
          if (typeof window.checkChanges === 'function') try { window.checkChanges(); } catch (_) {}
        }
        function applyColor(val, userInitiated){
          const normalized = normalizeHex(val);
          const _light = _lv_isLight();
          const display = normalized || (_light ? '#ffffff' : '#1b1b1b');
          picker.value = display; hex.value = display;
          preview.style.background = display;
          preview.style.borderColor = _light ? 'rgba(0,0,0,.14)' : 'rgba(255,255,255,.14)';
          preview.style.color = _light ? 'rgba(0,0,0,.8)' : 'rgba(255,255,255,.9)';
          if (userInitiated) {
            hidden.value = display;
            var presetSel = document.querySelector('select[name="THEME_PRESET"]');
            if (presetSel && presetSel.value !== 'default') { presetSel.value = 'default'; try { presetSel.dispatchEvent(new Event('change', {bubbles:true})); } catch(e){} }
            try { hidden.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) {}
            forceEnableApply();
          } else { if (!hidden.value) hidden.value = ''; }
        }
        picker.addEventListener('input', () => applyColor(picker.value, true));
        hex.addEventListener('change', () => { var n = normalizeHex(hex.value); if (n) applyColor(n, true); else hex.value = hidden.value || picker.value || (_lv_isLight() ? '#ffffff' : '#1b1b1b'); });
        hex.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); var n = normalizeHex(hex.value); if (n) applyColor(n, true); else hex.value = hidden.value || picker.value || (_lv_isLight() ? '#ffffff' : '#1b1b1b'); } });
        applyColor(hidden.value || picker.value || (_lv_isLight() ? '#ffffff' : '#1b1b1b'), false);
      }
    })();

    // Reset to Defaults
    (function() {
      const resetBtn = document.getElementById('lvResetDefaults');
      if (!resetBtn) return;

      function enableApplyAndMarkDirty(form){
        const applyBtn = document.querySelector('[name="#apply"]');
        if (applyBtn) { applyBtn.disabled = false; applyBtn.removeAttribute('disabled'); applyBtn.classList.remove('disabled'); if (window.jQuery) try { window.jQuery(applyBtn).prop('disabled', false).removeClass('disabled'); } catch(_){} }
        var fields = form.querySelectorAll('input, select, textarea');
        fields.forEach(function(el) { if (el.type === 'submit' || el.type === 'button' || !el.getAttribute('name')) return; try { el.dispatchEvent(new Event('change', { bubbles: true })); } catch (_) {} });
        if (typeof window.checkChanges === 'function') try { window.checkChanges(); } catch (_) {}
      }

      const dashDefaults = {
        REFRESH_ENABLED:'1', REFRESH_INTERVAL:'10', LOG_FONT_SIZE:'1.125rem', LOG_BG_COLOR:'', LOG_FONT_FAMILY:'system',
        THEME_PRESET:'default', HIGHLIGHT_ENABLED:'1', HIGHLIGHT_MODE:'full', SYNTAX_HIGHLIGHTING:'0', SYNTAX_ENGINE:'hljs',
        SEARCH_ENABLED:'0', SEARCH_HIGHLIGHT:'0', AUTO_SCROLL_DEFAULT:'1', PAUSE_ON_HOVER:'0', TAIL_LINES:'0',
        SHOW_BADGES:'1', SHOW_TOTAL_LINES:'1', SHOW_TIMESTAMP:'1', SHOW_FILTER_DROPDOWN:'1', SHOW_TOAST:'1',
        EXPORT_FORMAT:'log', EXPORT_INCLUDE_TIMESTAMP:'1', VERSION_OVERRIDE:'auto'
      };
      const toolDefaults = {
        // TOOL_TAIL_LINES + TOOL_LOG_FONT_SIZE are the keys with UI knobs.
        // The source-list resets (TOOL_ENABLED_*) are handled separately
        // further down via the explicit jQuery setters below.
        TOOL_TAIL_LINES: '0',
        TOOL_LOG_FONT_SIZE: '1.125rem',
        TOOL_REFRESH_SECS: '5',
        TOOL_EXPORT_FORMAT: 'txt'
      };

      function resetFieldsFromDefaults(form, defs, colorIds) {
        Object.keys(defs).forEach(function(fieldName) {
          var value = defs[fieldName];
          // Toggle switch (hidden+checkbox pair)
          var hiddenEl = form.querySelector('input[type="hidden"][name="' + fieldName + '"]');
          var cbEl = form.querySelector('input[type="checkbox"][name="' + fieldName + '"]');
          if (hiddenEl && cbEl) {
            cbEl.checked = (value === '1');
            // Sync toggle text
            var tog = cbEl.closest('.lv-toggle');
            if (tog) {
              var txt = tog.parentElement.querySelector('.lv-toggle-txt');
              if (txt) {
                var onLabel = txt.getAttribute('data-on') || 'Enabled';
                var offLabel = txt.getAttribute('data-off') || 'Disabled';
                txt.textContent = cbEl.checked ? onLabel : offLabel;
                txt.className = 'lv-toggle-txt ' + (cbEl.checked ? 'on' : 'off');
              }
            }
            return;
          }
          // Select
          var select = form.querySelector('select[name="' + fieldName + '"]');
          if (select) { select.value = value; return; }
          // Hidden only
          if (hiddenEl) { hiddenEl.value = value; }
        });
        // Color picker sync
        if (colorIds) {
          var cpicker = document.getElementById(colorIds.picker);
          var chex = document.getElementById(colorIds.hex);
          var chidden = document.getElementById(colorIds.hidden);
          var cpreview = document.getElementById(colorIds.preview);
          if (cpicker && chex && chidden && cpreview) {
            var _light = _lv_isLight();
            var defaultColor = colorIds.defaultColor || (_light ? '#ffffff' : '#1b1b1b');
            cpicker.value = defaultColor; chex.value = defaultColor; chidden.value = '';
            cpreview.style.background = defaultColor;
            cpreview.style.borderColor = _light ? 'rgba(0,0,0,.14)' : 'rgba(255,255,255,.14)';
            cpreview.style.color = _light ? 'rgba(0,0,0,.8)' : 'rgba(255,255,255,.9)';
          }
        }
      }

      function isToolTabActive() {
        var tabTool = document.getElementById('lvTabTool');
        return tabTool && tabTool.classList.contains('active');
      }
      function isBackupTabActive() {
        var tabBackup = document.getElementById('lvTabBackup');
        return tabBackup && tabBackup.classList.contains('active');
      }
      function isAlertsTabActive() {
        var tabAlerts = document.getElementById('lvTabAlerts');
        return tabAlerts && tabAlerts.classList.contains('active');
      }

      resetBtn.addEventListener('click', function() {
        var form = document.querySelector('form[name="scriptlogs_settings"]');
        if (!form) return;
        if (isAlertsTabActive()) {
          var cb = form.querySelector('input[type="checkbox"][name="ALERTS_ENABLED"]'); if (cb) cb.checked = false;
          var sel = form.querySelector('select[name="ALERTS_INTERVAL"]'); if (sel) sel.value = '2';
          if (typeof _lvAlertRules !== 'undefined') {
            _lvAlertRules = [];
            _lvAlertRulesLoaded = true;
            if (typeof lvRenderAllRules === 'function') lvRenderAllRules();
            if (typeof lvSerializeRules === 'function') lvSerializeRules();
          }
        } else if (isBackupTabActive()) {
          var cb = form.querySelector('input[type="checkbox"][name="BACKUP_ENABLED"]'); if (cb) cb.checked = false;
          var ret = form.querySelector('select[name="BACKUP_RETENTION"]'); if (ret) ret.value = '3';
          var st = form.querySelector('input[name="BACKUP_STORAGE"]'); if (st) st.value = '/mnt/user/appdata/Logs-Viewer-Backup';
          var sc = form.querySelector('select[name="BACKUP_SCHEDULE"]'); if (sc) sc.value = '23';
          try { $('#lvBackupEnabledSystemLogs').val(''); $('#lvBackupEnabledDockerContainers').val(''); $('#lvBackupEnabledVms').val(''); if (typeof lvLoadSourcesScoped === 'function') lvLoadSourcesScoped('Backup'); } catch(_){}
        } else if (isToolTabActive()) {
          // Tool tab only has TOOL_TAIL_LINES + source-list state to reset.
          // No color picker, no font/theme/highlight settings any more.
          resetFieldsFromDefaults(form, toolDefaults);
          try { $('#lvToolEnabledSystemLogs').val('syslog,dmesg,graphql-api.log,nginx-error'); $('#lvToolEnabledDockerContainers').val(''); $('#lvToolEnabledVms').val(''); } catch(_){}
          if (typeof lvLoadSourcesScoped === 'function') lvLoadSourcesScoped('Tool', function(){ enableApplyAndMarkDirty(form); });
        } else {
          resetFieldsFromDefaults(form, dashDefaults, { picker:'lvBgColorPicker', hex:'lvBgColorHex', hidden:'lvBgColorHidden', preview:'lvBgPreview' });
          try { $('#lvDashEnabledSystemLogs').val('syslog,dmesg,graphql-api.log,nginx-error'); $('#lvDashEnabledDockerContainers').val(''); $('#lvDashEnabledVms').val(''); } catch(_){}
          if (typeof lvLoadSourcesScoped === 'function') lvLoadSourcesScoped('Dash', function(){ enableApplyAndMarkDirty(form); });
        }
        try {
          if (isToolTabActive()) { localStorage.removeItem('logsviewer_panel_height_tool'); localStorage.removeItem('logsviewer_autoscroll_tool'); localStorage.removeItem('logsviewer_syntax_v4_tool'); localStorage.setItem('logsviewer_panel_height_reset_tool','1'); }
          else if (!isBackupTabActive() && !isAlertsTabActive()) { localStorage.removeItem('logsviewer_panel_height_dash'); localStorage.removeItem('logsviewer_autoscroll_dash'); localStorage.removeItem('logsviewer_syntax_v4_dash'); localStorage.setItem('logsviewer_panel_height_reset_dash','1'); }
        } catch(_){}
        enableApplyAndMarkDirty(form);
        lvShowResetModal();
      });

      // Tab switching
      (function(){
        var tabDash = document.getElementById('lvTabDashboard');
        var tabTool = document.getElementById('lvTabTool');
        var tabBackup = document.getElementById('lvTabBackup');
        var tabAlerts = document.getElementById('lvTabAlerts');
        var dashPanel = document.getElementById('lvDashboardPanel');
        var toolPanel = document.getElementById('lvToolPanel');
        var backupPanel = document.getElementById('lvBackupPanel');
        var alertsPanel = document.getElementById('lvAlertsPanel');
        var resetDefaultsBtn = document.getElementById('lvResetDefaults');

        function setActive(which){
          tabDash.classList.toggle('active', which === 'dash');
          tabTool.classList.toggle('active', which === 'tool');
          if (tabBackup) tabBackup.classList.toggle('active', which === 'backup');
          if (tabAlerts) tabAlerts.classList.toggle('active', which === 'alerts');
          dashPanel.style.display = (which === 'dash') ? '' : 'none';
          toolPanel.style.display = (which === 'tool') ? '' : 'none';
          if (backupPanel) backupPanel.style.display = (which === 'backup') ? '' : 'none';
          if (alertsPanel) alertsPanel.style.display = (which === 'alerts') ? '' : 'none';
          if (resetDefaultsBtn) resetDefaultsBtn.style.display = '';
          if (which === 'dash' && !dashPanel._sourcesLoaded) { dashPanel._sourcesLoaded = true; lvLoadSourcesScoped('Dash'); }
          if (which === 'tool' && !toolPanel._sourcesLoaded) { toolPanel._sourcesLoaded = true; lvLoadSourcesScoped('Tool'); }
          // Custom paths are shared between Tool & Dashboard: re-render so freshly switched tab shows current state
          if ((which === 'tool' || which === 'dash') && typeof lvRenderCustomPaths === 'function') { lvRenderCustomPaths(); }
          if (which === 'backup' && backupPanel && !backupPanel._sourcesLoaded) { backupPanel._sourcesLoaded = true; lvLoadSourcesScoped('Backup'); lvLoadBackupCalendar(); }
          if (which === 'alerts' && alertsPanel && !alertsPanel._loaded) { alertsPanel._loaded = true; lvLoadAlertRules(); lvLoadAlertHistory(); }
          try { sessionStorage.setItem('logsviewer_active_tab', which); } catch(e) {}
          var tabInput = document.getElementById('lvActiveTabInput');
          if (tabInput) tabInput.value = which;
          try { history.replaceState(null, '', '#' + which); } catch(e) {}
        }
        function onKey(e, which){ if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setActive(which); } }
        if (tabDash) { tabDash.addEventListener('click', () => setActive('dash')); tabDash.addEventListener('keydown', (e)=>onKey(e,'dash')); }
        if (tabTool) { tabTool.addEventListener('click', () => setActive('tool')); tabTool.addEventListener('keydown', (e)=>onKey(e,'tool')); }
        if (tabBackup) { tabBackup.addEventListener('click', () => setActive('backup')); tabBackup.addEventListener('keydown', (e)=>onKey(e,'backup')); }
        if (tabAlerts) { tabAlerts.addEventListener('click', () => setActive('alerts')); tabAlerts.addEventListener('keydown', (e)=>onKey(e,'alerts')); }
        try {
          var hash = (window.location.hash || '').replace('#', '');
          var postTab = (document.getElementById('lvActiveTabInput') || {}).value || 'dash';
          var savedTab = ''; try { savedTab = sessionStorage.getItem('logsviewer_active_tab') || ''; } catch(e){}
          var target = 'dash';
          if (['tool','dash','dashboard','backup','alerts'].indexOf(hash) !== -1) { target = (hash === 'dashboard') ? 'dash' : hash; }
          else if (['tool','dash','backup','alerts'].indexOf(postTab) !== -1) { target = postTab; }
          else if (['tool','dash','backup','alerts'].indexOf(savedTab) !== -1) { target = savedTab; }
          setActive(target);
        } catch(e) {}
      })();

      // Tab persistence on Apply
      (function(){
        function getCurrentTab() {
          var tabInput = document.getElementById('lvActiveTabInput');
          if (tabInput && ['tool','dash','backup','alerts'].indexOf(tabInput.value) !== -1) return tabInput.value;
          try { return sessionStorage.getItem('logsviewer_active_tab') || 'dash'; } catch(e) {} return 'dash';
        }
        function syncAll() {
          var current = getCurrentTab();
          var tabInput = document.getElementById('lvActiveTabInput');
          if (tabInput) tabInput.value = current;
          try { history.replaceState(null, '', '#' + current); } catch(e) {}
          try { sessionStorage.setItem('logsviewer_active_tab', current); } catch(e) {}
        }
        var applyBtn = document.querySelector('[name="#apply"]');
        if (applyBtn) { applyBtn.addEventListener('mousedown', syncAll); applyBtn.addEventListener('click', syncAll); }
        var form = document.querySelector('form[name="scriptlogs_settings"]');
        if (form) form.addEventListener('submit', syncAll);
      })();

      // ── Intercept form submit via AJAX (StreamViewer-style Apply animation) ──
      (function(){
        var form     = document.querySelector('form[name="scriptlogs_settings"]');
        var applyBtn = document.getElementById('lvApplyBtn');
        if (!form || !applyBtn) return;

        function ajaxSubmitForm(e) {
          if (e) e.preventDefault();

          // Disable button + spinner while saving
          applyBtn.disabled = true;
          applyBtn.classList.add('disabled');
          applyBtn.innerHTML = '<i class="fa fa-spinner fa-spin" aria-hidden="true"></i> Saving\u2026';

          // Serialize the form (works reliably with Unraid .page files)
          var params = (window.jQuery ? window.jQuery(form).serialize() : '');
          if (!params) {
            // Fallback: build manually if jQuery is missing for any reason
            try {
              var fd = new FormData(form);
              var parts = [];
              fd.forEach(function(v, k) { parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(v)); });
              params = parts.join('&');
            } catch(_) {}
          }
          params += '&%23apply=apply'; // add #apply (URL-encoded)

          if (!window.jQuery) {
            // Plain XHR fallback
            var xhr = new XMLHttpRequest();
            xhr.open('POST', window.location.pathname, true);
            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded; charset=UTF-8');
            xhr.timeout = 20000;
            xhr.onload = function() {
              if (xhr.status >= 200 && xhr.status < 400) { window.location.reload(); }
              else { onError(xhr.status); }
            };
            xhr.onerror = function() { onError(0); };
            xhr.ontimeout = function() { onError('timeout'); };
            xhr.send(params);
          } else {
            window.jQuery.ajax({
              url:     window.location.pathname,
              method:  'POST',
              data:    params,
              timeout: 20000,
              success: function() {
                // Preserve active tab across reload via hash (already synced by previous IIFE)
                var hash = '';
                try {
                  var tab = sessionStorage.getItem('logsviewer_active_tab') || '';
                  if (tab) hash = '#' + tab;
                } catch(_) {}
                window.location.href = window.location.href.split('#')[0] + hash;
                window.location.reload();
              },
              error: function(xhr) { onError(xhr && xhr.status); }
            });
          }
        }

        function onError(status) {
          alert('Save failed' + (status ? ' (HTTP ' + status + ')' : '') + '. Please try again.');
          applyBtn.disabled = false;
          applyBtn.classList.remove('disabled');
          applyBtn.innerHTML = '<i class="fa fa-check" aria-hidden="true"></i> Apply';
        }

        applyBtn.addEventListener('click', ajaxSubmitForm);
        form.addEventListener('submit', ajaxSubmitForm);
      })();

      // Log Sources discovery
      function lvFormatSize(bytes) {
        if (!bytes || bytes <= 0) return '0 B';
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
      }
      function lvRenderSourceRow(key, name, extraInfo, size, checked, disabled, statusHtml) {
        var dis = disabled ? ' lv-source-disabled' : '';
        var chk = (checked && !disabled) ? ' checked' : '';
        var disAttr = disabled ? ' disabled' : '';
        return '<div class="lv-source-row' + dis + '">' +
          '<div class="lv-source-label">' +
            '<input type="checkbox" class="lv-source-check" data-key="' + key + '"' + chk + disAttr + '>' +
            '<span class="lv-source-name">' + name + '</span>' +
          '</div>' +
          '<div class="lv-source-field">' +
            (extraInfo ? '<span class="lv-source-path">' + extraInfo + '</span>' : '') +
            (statusHtml || '') +
            '<span class="lv-source-size">' + lvFormatSize(size) + '</span>' +
          '</div>' +
        '</div>';
      }

      function lvCsvToSet(csv) {
        var set = {};
        (csv || '').split(',').map(function(x){ return (x||'').trim(); }).filter(Boolean).forEach(function(k){ set[k]=true; });
        return set;
      }
      function lvSyncScopedInputs(scope) {
        var sys = [], docker = [], vms = [], custom = [];
        $('#lv' + scope + 'SystemLogsList .lv-source-check:checked').each(function(){ sys.push($(this).data('key')); });
        $('#lv' + scope + 'DockerLogsList .lv-source-check:checked').each(function(){ docker.push($(this).data('key')); });
        $('#lv' + scope + 'VmLogsList .lv-source-check:checked').each(function(){ vms.push($(this).data('key')); });
        $('#lv' + scope + 'CustomLogsList .lv-source-check:checked').each(function(){ custom.push($(this).data('key')); });
        $('#lv' + scope + 'EnabledSystemLogs').val(sys.join(','));
        $('#lv' + scope + 'EnabledDockerContainers').val(docker.join(','));
        $('#lv' + scope + 'EnabledVms').val(vms.join(','));
        if ($('#lv' + scope + 'EnabledCustomLogs').length) {
          $('#lv' + scope + 'EnabledCustomLogs').val(custom.join(','));
        }
      }
      function lvLoadSourcesScoped(scope, doneCb) {
        var sysSet    = lvCsvToSet($('#lv' + scope + 'EnabledSystemLogs').val());
        var dkSet     = lvCsvToSet($('#lv' + scope + 'EnabledDockerContainers').val());
        var vmSet     = lvCsvToSet($('#lv' + scope + 'EnabledVms').val());
        var customSet = lvCsvToSet($('#lv' + scope + 'EnabledCustomLogs').val());
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'discover_sources', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 15000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            var sysHtml = '';
            if (data.system && data.system.sources) {
              data.system.sources.forEach(function(s) {
                if (scope === 'Backup' && s.key === 'syslog-previous') return;
                var checked = !!sysSet[s.key];
                var isZero = (parseInt(s.size, 10) || 0) === 0;
                sysHtml += lvRenderSourceRow(s.key, s.name, s.path, s.size, checked, (!s.exists || isZero), '');
              });
            }
            $('#lv' + scope + 'SystemLogsList').html(sysHtml || '<div class="lv-sources-loading">No system logs found.</div>');
            if (sysHtml) $('#lv' + scope + 'SystemActions').css('display','flex');

            if (data.docker && data.docker.available) {
              var dkHtml = '';
              if (data.docker.sources.length > 0) {
                data.docker.sources.forEach(function(c){
                  var dotClass = (c.status === 'running') ? 'running' : (c.status === 'exited' ? 'exited' : 'stopped');
                  var statusHtml = '<span class="lv-source-status"><span class="lv-status-dot ' + dotClass + '"></span>' + c.status + '</span>';
                  var checked = !!dkSet[c.name];
                  var isZero = (parseInt(c.log_size, 10) || 0) === 0;
                  dkHtml += lvRenderSourceRow(c.name, c.name, '', c.log_size, checked, isZero, statusHtml);
                });
              } else { dkHtml = '<div class="lv-sources-loading">No Docker containers found.</div>'; }
              $('#lv' + scope + 'DockerActions').css('display','flex');
              $('#lv' + scope + 'DockerLogsList').html(dkHtml);
              $('#lv' + scope + 'DockerUnavailable').hide();
            } else {
              $('#lv' + scope + 'DockerLogsList').empty();
              $('#lv' + scope + 'DockerUnavailable').show();
              $('#lv' + scope + 'DockerActions').hide();
            }

            if (data.vm && data.vm.available) {
              var vmHtml = '';
              if (data.vm.sources.length > 0) {
                data.vm.sources.forEach(function(v) {
                  var dotClass = (v.status === 'running') ? 'running' : 'shut';
                  var statusHtml = '<span class="lv-source-status"><span class="lv-status-dot ' + dotClass + '"></span>' + v.status + '</span>';
                  var checked = !!vmSet[v.name];
                  var isZero = (parseInt(v.log_size, 10) || 0) === 0;
                  vmHtml += lvRenderSourceRow(v.name, v.name, v.log_path, v.log_size, checked, isZero, statusHtml);
                });
              } else { $('#lv' + scope + 'VmUnavailable').show(); }
              $('#lv' + scope + 'VmLogsList').html(vmHtml);
              $('#lv' + scope + 'VmActions').css('display','flex');
            } else {
              $('#lv' + scope + 'VmLogsList').empty();
              $('#lv' + scope + 'VmUnavailable').show();
            }

            // Custom logs are rendered client-side from _lvCustomPaths state
            // (so newly-added rows appear before the user clicks Apply).
            if (typeof lvRenderCustomLogCheckboxes === 'function') {
              lvRenderCustomLogCheckboxes(scope);
            }
            lvSyncScopedInputs(scope);
            if (typeof doneCb === 'function') doneCb();
          },
          error: function() {
            $('#lv' + scope + 'SystemLogsList').html('<div class="lv-sources-loading" style="color:#e74c3c;">Failed to load sources.</div>');
            if (typeof doneCb === 'function') doneCb();
          }
        });
      }

