                foreach([3=>'3s',5=>'5s',10=>'10s - Default',20=>'20s',30=>'30s',60=>'60s'] as $v=>$l) echo '<option value="'.$v.'"'.($ri==(string)$v?' selected':'').'>'.$l.'</option>'; ?>
