        $('#lv' + scope + 'CustomDeselectAll').on('click', function(){ $('#lv' + scope + 'CustomLogsList .lv-source-check:not(:disabled)').prop('checked',false); lvSyncScopedInputs(scope); var f=document.forms['scriptlogs_settings']; if(f) enableApplyAndMarkDirty(f); });
