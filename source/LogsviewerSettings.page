          $pkg_files = glob('/var/log/packages/logsviewer-*');
          if ($pkg_files && preg_match('/logsviewer-(\d{4}\.\d{2}\.\d{2}[a-z]?)/', basename(end($pkg_files)), $matches)) $plugin_version = $matches[1];
