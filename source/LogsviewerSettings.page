      // Backup: Calendar
      var _lvCalYear, _lvCalMonth, _lvCalBackups = [];

      function lvLoadBackupCalendar() {
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'list_backups', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            _lvCalBackups = (data.backups || []);
            var now = new Date();
            _lvCalYear = now.getFullYear();
            _lvCalMonth = now.getMonth();
            lvRenderCalendar();
            if (!_lvCalBackups.length) {
              $('#lvCalEmpty').show();
            } else {
              $('#lvCalEmpty').hide();
            }
          },
          error: function() {
            $('#lvCalEmpty').text('Failed to load backups.').show();
          }
        });
      }

      function lvRenderCalendar() {
        var grid = document.getElementById('lvCalGrid');
        var monthLabel = document.getElementById('lvCalMonth');
        if (!grid || !monthLabel) return;

        var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        monthLabel.textContent = months[_lvCalMonth] + ' ' + _lvCalYear;

        // Remove old day cells (keep 7 header cells)
        while (grid.children.length > 7) grid.removeChild(grid.lastChild);

        var firstDay = new Date(_lvCalYear, _lvCalMonth, 1).getDay();
        var startOffset = (firstDay === 0) ? 6 : firstDay - 1; // Monday-based
        var daysInMonth = new Date(_lvCalYear, _lvCalMonth + 1, 0).getDate();
        var today = new Date();
        var todayStr = today.getFullYear() + '-' + String(today.getMonth()+1).padStart(2,'0') + '-' + String(today.getDate()).padStart(2,'0');

        // Build set of available dates
        var availSet = {};
        _lvCalBackups.forEach(function(b) { availSet[b.date] = b; });

        // Empty cells for offset
        for (var i = 0; i < startOffset; i++) {
          var empty = document.createElement('div');
          empty.className = 'lv-cal-day lv-cal-day--empty';
          grid.appendChild(empty);
        }

        for (var d = 1; d <= daysInMonth; d++) {
          var dateStr = _lvCalYear + '-' + String(_lvCalMonth+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
          var cell = document.createElement('div');
          cell.className = 'lv-cal-day';
          cell.textContent = d;
          cell.setAttribute('data-date', dateStr);

          if (dateStr === todayStr) cell.classList.add('lv-cal-day--today');
          if (dateStr > todayStr) cell.classList.add('lv-cal-day--future');
          if (availSet[dateStr]) {
            cell.classList.add('lv-cal-day--has');
            cell.addEventListener('click', (function(ds) {
              return function() {
                grid.querySelectorAll('.lv-cal-day--sel').forEach(function(el) { el.classList.remove('lv-cal-day--sel'); });
                this.classList.add('lv-cal-day--sel');
                lvShowDownload(ds);
              };
            })(dateStr));
          }
          grid.appendChild(cell);
        }
      }

      function lvShowDownload(dateStr) {
        var dlPanel = document.getElementById('lvCalDownload');
        var dlName = document.getElementById('lvCalDlName');
        var dlMeta = document.getElementById('lvCalDlMeta');
        var dlBtn = document.getElementById('lvCalDlBtn');
        if (!dlPanel) return;

        var backup = null;
        _lvCalBackups.forEach(function(b) { if (b.date === dateStr) backup = b; });
        if (!backup) { dlPanel.style.display = 'none'; return; }

        dlName.textContent = 'logsviewer-' + backup.date + '.zip';
        var parts = [];
        if (backup.contents.system > 0) parts.push('System (' + backup.contents.system + ')');
        if (backup.contents.docker > 0) parts.push('Docker (' + backup.contents.docker + ')');
        if (backup.contents.vms > 0) parts.push('VMs (' + backup.contents.vms + ')');
        dlMeta.textContent = (parts.length ? parts.join(' + ') : 'Empty') + '  ' + lvFormatSize(backup.size);

        dlBtn.href = '/plugins/logsviewer/include/logsviewer_api.php?action=download_backup&date=' + encodeURIComponent(backup.date) + '&_lvt=' + encodeURIComponent(window.lvToken || '');
        dlPanel.style.display = 'flex';
      }

      // Calendar navigation
      $('#lvCalPrev').on('click', function() {
        _lvCalMonth--;
        if (_lvCalMonth < 0) { _lvCalMonth = 11; _lvCalYear--; }
        lvRenderCalendar();
      });
      $('#lvCalNext').on('click', function() {
        var now = new Date();
        if (_lvCalYear > now.getFullYear() || (_lvCalYear === now.getFullYear() && _lvCalMonth >= now.getMonth())) return;
        _lvCalMonth++;
        if (_lvCalMonth > 11) { _lvCalMonth = 0; _lvCalYear++; }
        lvRenderCalendar();
      });

      // ═══════════ ALERTS ═══════════

      var _lvAlertRules = [];
      var _lvAlertRulesLoaded = false;

      var _lvAlertPresets = [
        { name: 'Failed Login', pattern: 'Failed password|authentication failure|Unsuccessful login', is_regex: true, severity: 'warning', sources: ['syslog'], cooldown: '0' },
        { name: 'Disk Error', pattern: 'disk error|I/O error|sector error|SMART error', is_regex: true, severity: 'critical', sources: ['syslog', 'dmesg'], cooldown: '300' },
        { name: 'Out of Memory', pattern: 'Out of memory|oom-killer|OOM', is_regex: true, severity: 'critical', sources: ['syslog', 'dmesg'], cooldown: '900' },
        { name: 'Kernel Panic', pattern: 'kernel panic|BUG:|Oops:', is_regex: true, severity: 'critical', sources: ['syslog', 'dmesg'], cooldown: '0' },
        { name: 'Array Error', pattern: 'md/unraid.*error|array.*error|parity.*error', is_regex: true, severity: 'critical', sources: ['syslog'], cooldown: '300' },
        { name: 'Docker Crash', pattern: 'container died|OOMKilled|exit code', is_regex: true, severity: 'warning', sources: ['docker'], cooldown: '300' }
      ];

      var _lvCooldownOptions = [
        { value: '0', label: 'None (every match)' },
        { value: '300', label: '5 minutes' },
        { value: '900', label: '15 minutes' },
        { value: '1800', label: '30 minutes' },
        { value: '3600', label: '1 hour' },
        { value: '21600', label: '6 hours' },
        { value: '86400', label: '24 hours' }
      ];

      function lvGenRuleId() { return 'rule_' + Date.now() + '_' + Math.floor(Math.random() * 1000); }

      function lvEscAttr(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      function lvRenderAlertRule(rule, index) {
        var sevOpts = ['info','warning','critical'].map(function(s) {
          return '<option value="' + s + '"' + (rule.severity === s ? ' selected' : '') + '>' + s.charAt(0).toUpperCase() + s.slice(1) + '</option>';
        }).join('');
        var cdOpts = _lvCooldownOptions.map(function(o) {
          return '<option value="' + o.value + '"' + (String(rule.cooldown) === o.value ? ' selected' : '') + '>' + o.label + '</option>';
        }).join('');
        var checked = (rule.enabled !== false) ? ' checked' : '';
        var regexChecked = rule.is_regex ? ' checked' : '';

        return '<div class="lv-alert-rule" data-index="' + index + '">' +
          '<div class="lv-alert-rule-hd">' +
            '<input type="checkbox" class="lv-source-check lv-alert-rule-enabled" title="Enable/Disable"' + checked + '>' +
            '<input type="text" class="lv-alert-rule-name" value="' + lvEscAttr(rule.name) + '" placeholder="Rule name">' +
            '<button type="button" class="lv-action-btn lv-alert-rule-remove" title="Remove rule"><i class="fa fa-trash"></i></button>' +
          '</div>' +
          '<div class="lv-alert-rule-bd">' +
            '<div class="lv-alert-rule-row">' +
              '<span class="lv-alert-rule-lbl">Pattern</span>' +
              '<input type="text" class="lv-alert-rule-pattern" value="' + lvEscAttr(rule.pattern) + '" placeholder="Text or regex pattern">' +
              '<label class="lv-alert-rule-regex" title="Use regex"><input type="checkbox" class="lv-alert-rule-is-regex"' + regexChecked + '> Regex</label>' +
            '</div>' +
            '<div class="lv-alert-rule-row">' +
              '<span class="lv-alert-rule-lbl">Severity</span>' +
              '<select class="lv-alert-rule-severity lv-select">' + sevOpts + '</select>' +
              '<span class="lv-alert-rule-lbl" style="margin-left:12px">Cooldown</span>' +
              '<select class="lv-alert-rule-cooldown lv-select">' + cdOpts + '</select>' +
            '</div>' +
            '<div class="lv-alert-rule-row">' +
              '<span class="lv-alert-rule-lbl">Sources</span>' +
              '<div class="lv-alert-rule-sources">' + lvRenderSourceCheckboxes(rule.sources || []) + '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
      }

      function lvRenderSourceCheckboxes(selected) {
        var sysLogs = ['syslog','dmesg','graphql-api.log','nginx-error','phplog','libvirt'];
        var sysNames = { syslog:'Syslog', dmesg:'Dmesg', 'graphql-api.log':'GraphQL API', 'nginx-error':'Nginx Errors', phplog:'PHP Log', libvirt:'Libvirt' };
        var html = '';
        sysLogs.forEach(function(key) {
          var chk = (selected.indexOf(key) !== -1) ? ' checked' : '';
          html += '<label class="lv-alert-src-chk"><input type="checkbox" value="' + key + '"' + chk + '> ' + (sysNames[key] || key) + '</label>';
        });
        var dkChk = (selected.indexOf('docker') !== -1) ? ' checked' : '';
        html += '<label class="lv-alert-src-chk lv-alert-src-sep"><input type="checkbox" value="docker"' + dkChk + '> Docker (all containers)</label>';
        return html;
      }

      function lvSerializeRules() {
        var rules = [];
        $('#lvAlertRulesList .lv-alert-rule').each(function() {
          var $r = $(this);
          var sources = [];
          $r.find('.lv-alert-rule-sources input:checked').each(function() { sources.push($(this).val()); });
          rules.push({
            id: $r.data('rule-id') || lvGenRuleId(),
            name: $r.find('.lv-alert-rule-name').val(),
            pattern: $r.find('.lv-alert-rule-pattern').val(),
            is_regex: $r.find('.lv-alert-rule-is-regex').is(':checked'),
            severity: $r.find('.lv-alert-rule-severity').val(),
            sources: sources,
            cooldown: $r.find('.lv-alert-rule-cooldown').val(),
            enabled: $r.find('.lv-alert-rule-enabled').is(':checked')
          });
        });
        _lvAlertRules = rules;
        if (_lvAlertRulesLoaded) {
          $('#lvAlertRulesJson').val(JSON.stringify(rules));
        }
      }

      function lvLoadAlertRules() {
        _lvAlertRulesLoaded = false;
        $('#lvAlertAddRule, #lvAlertAddPresets').prop('disabled', true).addClass('disabled');
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'get_alert_rules', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            _lvAlertRules = data.rules || [];
            _lvAlertRulesLoaded = true;
            lvRenderAllRules();
            $('#lvAlertAddRule, #lvAlertAddPresets').prop('disabled', false).removeClass('disabled');
          },
          error: function() {
            _lvAlertRulesLoaded = true;
            _lvAlertRules = [];
            $('#lvAlertRulesList').html('<div class="lv-sources-loading" style="color:#e74c3c;">Failed to load rules. You can still add new rules below.</div>');
            $('#lvAlertAddRule, #lvAlertAddPresets').prop('disabled', false).removeClass('disabled');
          }
        });
      }

      function lvRenderAllRules() {
        var html = '';
        if (_lvAlertRules.length === 0) {
          html = '<div class="lv-sources-loading">No alert rules configured. Click "Add Rule" or "Add Common Rules" to get started.</div>';
        } else {
          _lvAlertRules.forEach(function(rule, i) {
            html += lvRenderAlertRule(rule, i);
          });
        }
        $('#lvAlertRulesList').html(html);
        // Store rule IDs
        $('#lvAlertRulesList .lv-alert-rule').each(function(i) {
          $(this).data('rule-id', _lvAlertRules[i].id || lvGenRuleId());
        });
        lvSerializeRules();
      }

      // Add rule
      $('#lvAlertAddRule').on('click', function() {
        if (!_lvAlertRulesLoaded) return;
        _lvAlertRules.push({ id: lvGenRuleId(), name: '', pattern: '', is_regex: false, severity: 'warning', sources: ['syslog'], cooldown: '3600', enabled: true });
        lvRenderAllRules();
        var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      // Add preset rules
      $('#lvAlertAddPresets').on('click', function() {
        if (!_lvAlertRulesLoaded) return;
        var existingNames = {};
        _lvAlertRules.forEach(function(r) { existingNames[r.name] = true; });
        var added = 0;
        _lvAlertPresets.forEach(function(preset) {
          if (!existingNames[preset.name]) {
            var rule = JSON.parse(JSON.stringify(preset));
            rule.id = lvGenRuleId();
            rule.enabled = true;
            _lvAlertRules.push(rule);
            added++;
          }
        });
        if (added > 0) {
          lvRenderAllRules();
          var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
        }
      });

      // Remove rule
      $(document).on('click', '.lv-alert-rule-remove', function() {
        var idx = $(this).closest('.lv-alert-rule').data('index');
        _lvAlertRules.splice(idx, 1);
        lvRenderAllRules();
        var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      // Rule field changes trigger serialize + dirty
      $(document).on('change input', '.lv-alert-rule input, .lv-alert-rule select', function() {
        lvSerializeRules();
        var f = document.forms['scriptlogs_settings']; if (f && typeof enableApplyAndMarkDirty === 'function') enableApplyAndMarkDirty(f);
      });

      // Alert History
      function lvLoadAlertHistory() {
        $.ajax({
          url: '/plugins/logsviewer/include/logsviewer_api.php',
          data: { action: 'get_alert_history', _lvt: window.lvToken || '' },
          dataType: 'json', timeout: 10000,
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          success: function(data) {
            var items = data.history || [];
            if (items.length === 0) {
              $('#lvAlertHistoryList').html('<div class="lv-sources-loading">No alerts triggered yet.</div>');
              return;
            }
            var html = '';
            items.slice(0, 100).forEach(function(a) {
              var sevClass = 'lv-alert-sev--' + (a.severity || 'info');
              html += '<div class="lv-alert-history-row">' +
                '<span class="lv-alert-history-time">' + (a.timestamp || '') + '</span>' +
                '<span class="lv-alert-history-badge ' + sevClass + '">' + (a.severity || 'info') + '</span>' +
                '<span class="lv-alert-history-name">' + (a.rule || '') + '</span>' +
                '<span class="lv-alert-history-src">' + (a.source || '') + '</span>' +
                '<div class="lv-alert-history-line">' + $('<span>').text(a.matched_line || '').html() + '</div>' +
              '</div>';
            });
            $('#lvAlertHistoryList').html(html);
          },
          error: function() {
            $('#lvAlertHistoryList').html('<div class="lv-sources-loading" style="color:#e74c3c;">Failed to load history.</div>');
          }
        });
      }

      $('#lvAlertRefreshHistory').on('click', function() { lvLoadAlertHistory(); });

      $('#lvAlertClearHistory').on('click', function() {
        var modal = document.getElementById('lvClearHistoryModal');
        if (modal) { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
      });

      // Clear History confirmation modal logic
      (function(){
        var modal = document.getElementById('lvClearHistoryModal');
        if (!modal) return;
        function closeModal() { modal.style.display = 'none'; document.body.style.overflow = ''; }
        document.getElementById('lvClearHistoryCancelBtn').addEventListener('click', closeModal);
        modal.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.style.display === 'flex') closeModal(); });
        document.getElementById('lvClearHistoryConfirmBtn').addEventListener('click', function(){
          closeModal();
          $.ajax({
            url: '/plugins/logsviewer/include/logsviewer_api.php',
            data: { action: 'clear_alert_history', _lvt: window.lvToken || '' },
            dataType: 'json', timeout: 10000,
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            success: function() { lvLoadAlertHistory(); }
          });
        });
      })();

      // Serialize rules on form submit
      var alertForm = document.querySelector('form[name="scriptlogs_settings"]');
      if (alertForm) {
        alertForm.addEventListener('submit', function() { lvSerializeRules(); });
      }

      // Reset confirmation modal
      function lvShowResetModal() {
        var modal = document.getElementById('lvResetModal');
        if (!modal) return;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
      (function(){
        var modal = document.getElementById('lvResetModal');
        var okBtn = document.getElementById('lvResetOkBtn');
        if (!modal) return;
        function close() { modal.style.display = 'none'; document.body.style.overflow = ''; }
        if (okBtn) okBtn.addEventListener('click', close);
        modal.addEventListener('click', function(e){ if (e.target === modal) close(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.style.display === 'flex') close(); });
      })();

      // Credits modal
      (function(){
        var modal = document.getElementById('lvCreditsModal');
        var link  = document.getElementById('lvCreditsLink');
        var okBtn = document.getElementById('lvCreditsOkBtn');
        if (!modal || !link) return;
        function openModal() { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
        function closeModal() { modal.style.display = 'none'; document.body.style.overflow = ''; }
        link.addEventListener('click', function(e){ e.preventDefault(); openModal(); });
        if (okBtn) okBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.style.display === 'flex') closeModal(); });
      })();
    })();
  </script>
</form>
